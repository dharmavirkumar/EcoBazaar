<!DOCTYPE html>
<html>
<head>
<title>Jewellery</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto px-4 sm:px-6 py-6">

  <!-- 🔥 HEADING -->
  <h1 class="text-2xl sm:text-3xl font-bold mb-6 text-center md:text-left">
    💍 Jewellery Collection
  </h1>

  <!-- GRID -->
  <div class="grid grid-cols-1 xs:grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 sm:gap-6">

  <% products.forEach(function(product){ %>

    <div class="bg-white rounded-xl shadow hover:shadow-xl transition duration-300 overflow-hidden group flex flex-col relative">

      <!-- ❤️ Wishlist -->
      <button class="absolute top-2 right-2 bg-white p-2 rounded-full shadow hover:bg-red-100">
        ❤️
      </button>

      <!-- IMAGE -->
      <div class="overflow-hidden">
        <img 
          src="<%= product.image %>" 
          onerror="this.src='https://via.placeholder.com/300'"
          class="w-full h-44 sm:h-48 object-cover group-hover:scale-110 transition duration-300"
        >
      </div>

      <!-- CONTENT -->
      <div class="p-4 flex flex-col flex-grow">

        <!-- NAME -->
        <h2 class="text-sm sm:text-base font-semibold truncate">
          <%= product.name.substring(0, 30) %>
        </h2>

        <!-- PRICE -->
        <p class="text-green-600 font-bold text-lg mt-1">
          ₹ <%= product.price %>
        </p>

        <!-- DELIVERY -->
        <p class="text-xs text-gray-500 mt-1">
          🚚 Free Delivery
        </p>

        <!-- RATING -->
        <p class="text-yellow-500 text-sm mt-1">
          ⭐ <%= typeof product.avgRating !== "undefined" ? product.avgRating.toFixed(1) : "No rating" %>
        </p>

        <!-- DESCRIPTION -->
        <p class="text-gray-500 text-xs sm:text-sm mt-2 line-clamp-2">
          <%= product.description ? product.description.substring(0, 60) : "" %>...
        </p>

        <!-- BUTTONS -->
        <div class="flex gap-2 mt-4 mt-auto">

          <a href="/product/<%= product._id %>" 
            class="flex-1 text-center bg-blue-500 text-white py-2 text-sm rounded-lg hover:bg-blue-600 transition">
            View
          </a>

          <a href="/add-to-cart/<%= product._id %>" 
            class="flex-1 text-center bg-pink-500 text-white py-2 text-sm rounded-lg hover:bg-pink-600 transition">
            Cart
          </a>

        </div>

      </div>

    </div>

  <% }) %>

  </div>

</div>

<%- include("partial/footer") %>

</body>
</html>