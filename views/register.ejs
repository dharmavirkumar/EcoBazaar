

 <!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register | Your Store</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="min-h-screen flex items-center justify-center">

  <div class="bg-white shadow-2xl rounded-xl flex w-[900px] overflow-hidden">

    <!-- LEFT SIDE -->
    <div class="w-1/2 bg-gray-100 text-white p-10 flex flex-col justify-center">
      <h2 class="text-3xl font-bold mb-4">Join Us 🚀</h2>
      <p class="text-sm">
        Create your account to explore amazing products, track orders and enjoy shopping.
      </p>

      <img 
        src="https://cdn-icons-png.flaticon.com/512/5087/5087579.png" 
        class="mt-10 w-40 mx-auto">
    </div>

    <!-- RIGHT SIDE -->
    <div class="w-1/2 p-10">

      <h2 class="text-2xl font-bold mb-6 text-center">Create Account</h2>

      <form action="/register" method="POST" class="space-y-4">

        <!-- NAME -->
        <div>
          <label class="block text-gray-600 mb-1">Full Name</label>
          <input 
            type="text" 
            name="name" 
            required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400"
            placeholder="Enter your name">
        </div>

        <!-- EMAIL -->
        <div>
          <label class="block text-gray-600 mb-1">Email</label>
          <input 
            type="email" 
            name="email" 
            required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-green-400"
            placeholder="Enter your email">
        </div>

        <!-- PASSWORD -->
        <input type="password" id="password" name="password" placeholder="Enter password"
        class="w-full px-4 py-2 border rounded-lg">

        <!-- Strength bar -->
<div class="w-full bg-gray-200 h-2 rounded mt-2">
  <div id="strengthBar" class="h-2 rounded"></div>
</div>

<p id="strengthText" class="text-sm mt-1"></p>

        <!-- BUTTON -->
        <button 
          type="submit"
          class="w-full bg-green-600 text-white py-2 rounded-lg hover:bg-green-700 transition">
          Register
        </button>

      </form>

      <!-- LOGIN LINK -->
      <p class="text-sm text-center mt-4">
        Already have an account? 
        <a href="/login" class="text-green-600 font-semibold">Login</a>
      </p>

    </div>

  </div>
<!-- <a href="/auth/google"
class="block text-center bg-red-500 text-white py-2 rounded mt-4">
Login with Google
</a> -->

</div>

</body>
<script>
const password = document.getElementById("password");
const bar = document.getElementById("strengthBar");
const text = document.getElementById("strengthText");

password.addEventListener("input", () => {
  const val = password.value;
  let strength = 0;

  if (val.length > 5) strength++;
  if (val.match(/[A-Z]/)) strength++;
  if (val.match(/[0-9]/)) strength++;
  if (val.match(/[@$!%*?&]/)) strength++;

  if (strength === 1) {
    bar.style.width = "25%";
    bar.style.background = "red";
    text.innerText = "Weak";
  } 
  else if (strength === 2) {
    bar.style.width = "50%";
    bar.style.background = "orange";
    text.innerText = "Medium";
  } 
  else if (strength === 3) {
    bar.style.width = "75%";
    bar.style.background = "blue";
    text.innerText = "Strong";
  } 
  else if (strength === 4) {
    bar.style.width = "100%";
    bar.style.background = "green";
    text.innerText = "Very Strong 💪";
  }
});
</script>
</html>