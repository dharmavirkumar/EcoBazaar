<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Register | Your Store</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="min-h-screen flex items-center justify-center px-4">

  <!-- MAIN CONTAINER -->
  <div class="bg-white shadow-2xl rounded-2xl flex flex-col md:flex-row w-full max-w-5xl overflow-hidden">

    <!-- LEFT SIDE (Hidden on Mobile) -->
    <div class="hidden md:flex w-1/2 bg-gradient-to-br from-pink-500 to-red-500 text-white p-10 flex-col justify-center">

      <h2 class="text-3xl font-bold mb-4">Join Us 🚀</h2>
      <p class="text-sm opacity-90">
        Create your account to explore amazing products, track orders and enjoy shopping.
      </p>

      <img 
        src="https://cdn-icons-png.flaticon.com/512/5087/5087579.png" 
        class="mt-10 w-40 mx-auto">
    </div>

    <!-- RIGHT SIDE -->
    <div class="w-full md:w-1/2 p-6 md:p-10">

      <h2 class="text-2xl font-bold mb-6 text-center md:text-left">
        Create Account
      </h2>

      <form action="/register" method="POST" class="space-y-4">

        <!-- NAME -->
        <div>
          <label class="block text-gray-600 mb-1 text-sm">Full Name</label>
          <input 
            type="text" 
            name="name" 
            required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-400"
            placeholder="Enter your name">
        </div>

        <!-- EMAIL -->
        <div>
          <label class="block text-gray-600 mb-1 text-sm">Email</label>
          <input 
            type="email" 
            name="email" 
            required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-400"
            placeholder="Enter your email">
        </div>

        <!-- PASSWORD -->
        <div>
          <label class="block text-gray-600 mb-1 text-sm">Password</label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            required
            class="w-full px-4 py-2 border rounded-lg focus:outline-none focus:ring-2 focus:ring-pink-400"
            placeholder="Enter password">
        </div>

        <!-- Strength bar -->
        <div class="w-full bg-gray-200 h-2 rounded">
          <div id="strengthBar" class="h-2 rounded transition-all"></div>
        </div>

        <p id="strengthText" class="text-xs"></p>

        <!-- BUTTON -->
        <button 
          type="submit"
          class="w-full bg-pink-500 text-white py-2 rounded-lg hover:bg-pink-600 transition font-semibold">
          Register
        </button>

      </form>

      <!-- LOGIN LINK -->
      <p class="text-sm text-center mt-4">
        Already have an account? 
        <a href="/login" class="text-pink-500 font-semibold">Login</a>
      </p>

    </div>

  </div>

</div>

<script>
const password = document.getElementById("password");
const bar = document.getElementById("strengthBar");
const text = document.getElementById("strengthText");

password.addEventListener("input", () => {
  const val = password.value;
  let strength = 0;

  if (val.length > 5) strength++;
  if (val.match(/[A-Z]/)) strength++;
  if (val.match(/[0-9]/)) strength++;
  if (val.match(/[@$!%*?&]/)) strength++;

  if (strength === 1) {
    bar.style.width = "25%";
    bar.style.background = "red";
    text.innerText = "Weak";
  } 
  else if (strength === 2) {
    bar.style.width = "50%";
    bar.style.background = "orange";
    text.innerText = "Medium";
  } 
  else if (strength === 3) {
    bar.style.width = "75%";
    bar.style.background = "blue";
    text.innerText = "Strong";
  } 
  else if (strength === 4) {
    bar.style.width = "100%";
    bar.style.background = "green";
    text.innerText = "Very Strong 💪";
  } else {
    bar.style.width = "0%";
    text.innerText = "";
  }
});
</script>

</body>
</html>