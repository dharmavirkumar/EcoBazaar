<!DOCTYPE html>
<html>
<head>
  <title>Search Results</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-white">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto px-4 py-6">

  <!-- 🔍 SEARCH -->
  <form action="/search" method="GET" 
    class="mb-6 flex flex-col sm:flex-row gap-3">

    <input 
      type="text" 
      name="q"
      value="<%= query %>"
      placeholder="Search for products, brands..."
      class="w-full px-4 py-3 border rounded-md focus:outline-none focus:ring-1 focus:ring-gray-400"
    >

    <button class="bg-black text-white px-6 py-3 rounded-md">
      Search
    </button>

  </form>

  <!-- HEADER -->
  <h1 class="text-xl font-semibold mb-6">
    Results for "<%= query %>" 
    <span class="text-gray-500">(<%= products.length %>)</span>
  </h1>

  <div class="flex flex-col md:flex-row gap-6">

    <!-- 🧱 LEFT FILTER PANEL -->
    <div class="w-full md:w-1/4 border-r pr-4">

      <h2 class="font-semibold mb-4">FILTERS</h2>

      <!-- CATEGORY -->
      <!-- <div class="mb-6">
        <h3 class="font-medium mb-2">Category</h3>
        <ul class="space-y-1 text-sm text-gray-600">
          <li><input type="checkbox"> Shirts</li>
          <li><input type="checkbox"> T-Shirts</li>
          <li><input type="checkbox"> Jeans</li>
        </ul>
      </div> -->

      <!-- PRICE -->
      <div class="mb-6">
        <h3 class="font-medium mb-2">Price</h3>
        <ul class="space-y-1 text-sm text-gray-600">
          <li><input type="checkbox"> Under ₹500</li>
          <li><input type="checkbox"> ₹500 - ₹1000</li>
          <li><input type="checkbox"> ₹1000+</li>
        </ul>
      </div>

      <!-- RATING -->
      <div>
        <h3 class="font-medium mb-2">Rating</h3>
        <ul class="space-y-1 text-sm text-gray-600">
          <li><input type="checkbox"> ⭐ 4 & above</li>
          <li><input type="checkbox"> ⭐ 3 & above</li>
        </ul>
      </div>

    </div>

    <!-- 🛍 RIGHT PRODUCTS -->
    <div class="flex-1">

      <!-- SORT -->
      <div class="flex justify-end mb-4">
        <form method="GET" action="/search">
          <input type="hidden" name="q" value="<%= query %>">

          <select name="sort" onchange="this.form.submit()"
            class="border px-4 py-2 text-sm">
            <option value="">Sort By</option>
            <option value="low">Price Low to High</option>
            <option value="high">Price High to Low</option>
          </select>
        </form>
      </div>

      <% if(products.length === 0){ %>

      <!-- EMPTY -->
      <div class="text-center mt-20">
        <h2 class="text-xl font-semibold">No products found</h2>
        <p class="text-gray-500 mt-2">Try something else</p>
      </div>

      <% } else { %>

      <!-- GRID -->
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-6">

        <% products.forEach(product => { %>

        <div class="group cursor-pointer">

          <!-- IMAGE -->
          <a href="/product/<%= product._id %>" class="group block">

  <!-- IMAGE -->
  <div class="overflow-hidden bg-gray-100">
    <img 
      src="<%= product.images?.[0] || '/default.png' %>" 
      class="w-full h-56 object-cover group-hover:scale-105 transition duration-300"
    >
  </div>

  <!-- INFO -->
  <div class="mt-2">

    <h2 class="text-sm font-medium text-gray-800 line-clamp-1">
      <%= product.name %>
    </h2>

    <p class="text-xs text-gray-500">
      <%= product.category || "Brand" %>
    </p>

    <div class="mt-1 text-sm">
      <span class="font-semibold">
        ₹<%= product.finalPrice || product.price %>
      </span>
    </div>

  </div>

</a>
        </div>

        <% }) %>

      </div>

      <% } %>

    </div>

  </div>

</div>

<%- include("partial/footer") %>

</body>
</html>