<!DOCTYPE html>
<html>
<head>
  <title>Track Order</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-3xl mx-auto mt-6 bg-white p-5 rounded-xl shadow">

  <h2 class="text-xl font-bold mb-2">📦 Order Tracking</h2>

  <p class="text-sm"><b>Order ID:</b> <%= order._id %></p>
  <p class="text-sm mb-4">
    <b>Delivery by:</b> <%= new Date(order.estimatedDelivery).toDateString() %>
  </p>

  <!-- 🔥 PROGRESS LOGIC -->
  <%
  let progress = 25;
  if(order.status==="Shipped") progress=50;
  if(order.status==="Out for Delivery") progress=75;
  if(order.status==="Delivered") progress=100;
  %>

  <!-- 🔥 PROGRESS BAR -->
  <div class="w-full h-2 bg-gray-200 rounded overflow-hidden">
    <div class="h-full bg-blue-500 transition-all duration-500"
      style="width:<%= progress %>%"></div>
  </div>

  <!-- STEPS -->
  <div class="flex justify-between text-xs mt-2">
    <span class="<%= progress>=25 ? 'text-blue-600 font-semibold':'' %>">Placed</span>
    <span class="<%= progress>=50 ? 'text-blue-600 font-semibold':'' %>">Shipped</span>
    <span class="<%= progress>=75 ? 'text-blue-600 font-semibold':'' %>">Out</span>
    <span class="<%= progress>=100 ? 'text-blue-600 font-semibold':'' %>">Delivered</span>
  </div>

  <!-- 🧾 TIMELINE -->
  <div class="mt-6 border-l-2 border-blue-500 pl-4 space-y-4">

    <% order.statusHistory.forEach(s => { %>
      <div class="relative">

        <div class="absolute -left-[9px] top-1 w-4 h-4 bg-blue-500 rounded-full"></div>

        <p class="font-semibold text-sm">
          <%= s.status %>
        </p>

        <p class="text-xs text-gray-500">
          <%= new Date(s.date).toLocaleString() %>
        </p>

      </div>
    <% }) %>

  </div>

  <!-- 🚚 LIVE TRACKING -->
  <div class="mt-6 bg-gray-50 p-4 rounded-lg">

    <h3 class="font-semibold mb-3">🚚 Live Updates</h3>

    <!-- LOADER -->
    <div id="trackingData" class="text-sm text-gray-600">
      ⏳ Loading tracking...
    </div>

  </div>

</div>

<script>
async function loadTracking() {
  try {
    const res = await fetch("/api/track/<%= order._id %>");
    const data = await res.json();

    const box = document.getElementById("trackingData");

    if (!data || !data.ShipmentData || !data.ShipmentData.length) {
      box.innerHTML = "No tracking available 📭";
      return;
    }

    const scans = data.ShipmentData[0]?.Shipment?.Scans || [];

    if (!scans.length) {
      box.innerHTML = "Tracking not started yet ⏳";
      return;
    }

    box.innerHTML = scans.map(s => `
      <div class="border-b py-2">
        <p class="font-semibold text-gray-800">${s.ScanDetail.Status}</p>
        <p class="text-xs text-gray-500">${s.ScanDetail.Date}</p>
      </div>
    `).join("");

  } catch (err) {
    document.getElementById("trackingData").innerHTML =
      "Error loading tracking ❌";
  }
}

// 🔄 AUTO REFRESH
setInterval(loadTracking, 20000);

// FIRST LOAD
loadTracking();
</script>

</body>
</html>