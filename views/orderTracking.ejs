<!DOCTYPE html>
<html>
<head>
  <title>Track Order</title>

  <style>
    body {
      font-family: Arial;
      background:#f1f3f6;
    }

    .container {
      max-width: 800px;
      margin: 40px auto;
      background: #fff;
      padding: 25px;
      border-radius: 12px;
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    h2 { margin-bottom: 10px; }

    .progress-bar {
      width: 100%;
      height: 6px;
      background: #ddd;
      border-radius: 10px;
      margin: 20px 0;
      overflow: hidden;
    }

    .progress {
      height: 100%;
      background: #2874f0;
      transition: width 0.6s ease;
    }

    .steps {
      display: flex;
      justify-content: space-between;
      margin-top: 10px;
      font-size: 13px;
    }

    .steps span.active {
      color: #2874f0;
      font-weight: bold;
    }

    .timeline {
      margin-top: 25px;
    }

    .timeline-item {
      border-left: 3px solid #2874f0;
      padding-left: 10px;
      margin-bottom: 10px;
    }

    .tracking-box {
      margin-top: 25px;
      background: #fafafa;
      padding: 15px;
      border-radius: 8px;
    }

    .tracking-item {
      border-bottom: 1px solid #ddd;
      padding: 8px 0;
    }

  </style>
</head>

<body>

<div class="container">

  <h2>📦 Order Tracking</h2>

  <p><b>Order ID:</b> <%= order._id %></p>
  <p><b>Delivery by:</b> <%= new Date(order.estimatedDelivery).toDateString() %></p>

  <!-- 🔥 PROGRESS -->
  <%
  let progress = 25;
  if(order.status==="Shipped") progress=50;
  if(order.status==="Out for Delivery") progress=75;
  if(order.status==="Delivered") progress=100;
  %>

  <div class="progress-bar">
    <div class="progress" style="width:<%= progress %>%"></div>
  </div>

  <div class="steps">
    <span class="<%= progress>=25 ? 'active':'' %>">Placed</span>
    <span class="<%= progress>=50 ? 'active':'' %>">Shipped</span>
    <span class="<%= progress>=75 ? 'active':'' %>">Out</span>
    <span class="<%= progress>=100 ? 'active':'' %>">Delivered</span>
  </div>

  <!-- 🧾 TIMELINE -->
  <div class="timeline">
    <% order.statusHistory.forEach(s => { %>
      <div class="timeline-item">
        <b><%= s.status %></b><br>
        <small><%= new Date(s.date).toLocaleString() %></small>
      </div>
    <% }) %>
  </div>

  <!-- 🚚 LIVE TRACKING -->
  <div class="tracking-box">
    <h3>🚚 Live Updates</h3>
    <div id="trackingData">Loading...</div>
  </div>

</div>

<script>
async function loadTracking() {
  try {
    const res = await fetch("/api/track/<%= order._id %>");
    const data = await res.json();

    if (!data.ShipmentData) {
      document.getElementById("trackingData").innerHTML = "No tracking available";
      return;
    }

    const scans = data.ShipmentData[0].Shipment.Scans;

    document.getElementById("trackingData").innerHTML =
      scans.map(s => `
        <div class="tracking-item">
          <b>${s.ScanDetail.Status}</b><br>
          <small>${s.ScanDetail.Date}</small>
        </div>
      `).join("");

  } catch (err) {
    document.getElementById("trackingData").innerHTML = "Error loading tracking";
  }
}

// 🔥 AUTO REFRESH EVERY 20 SEC
setInterval(loadTracking, 20000);

loadTracking();
</script>

</body>
</html>