<!DOCTYPE html>
<html>
<head>
  <title>Admin Orders</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">
      Admin Orders 📦
    </h1>

    <span class="text-sm text-gray-500">
      Total Orders: <%= orders.length %>
    </span>
  </div>

  <% if(orders.length > 0){ %>

  <div class="overflow-x-auto bg-white rounded-xl shadow">

    <table class="w-full text-sm">

      <!-- HEADER -->
      <thead class="bg-gray-50 text-gray-600 uppercase text-xs sticky top-0">
        <tr>
          <th class="p-4 text-left">Product</th>
          <th class="p-4 text-center">Customer</th>
          <th class="p-4 text-center">Contact</th>
          <th class="p-4 text-left">Address</th>
          <th class="p-4 text-center">Payment</th>
          <th class="p-4 text-center">Size</th>
          <th class="p-4 text-center">Status</th>
          <th class="p-4 text-center">Action</th>
        </tr>
      </thead>

      <!-- BODY -->
      <tbody class="divide-y">

      <% orders.forEach(order => { %>

        <tr class="hover:bg-gray-50 transition">

          <!-- PRODUCT -->
          <td class="p-4">
            <% if(order.productId){ %>

              <div class="flex items-center gap-3">

                <img 
                  src="<%= order.productId?.images?.[0] || '/default.png' %>" 
                  class="w-16 h-16 object-cover rounded-lg border">

                <div>
                  <p class="font-semibold text-gray-800">
                    <%= order.productId.name %>
                  </p>
                  <p class="text-gray-500 text-xs">
                    ₹ <%= order.productId.price %>
                  </p>
                </div>

              </div>

            <% } else { %>
              <p class="text-red-500 font-medium">Product Deleted</p>
            <% } %>
          </td>

          <!-- CUSTOMER -->
          <td class="p-4 text-center">
            <p class="font-medium text-gray-700">
              <%= order.name %>
            </p>
          </td>

          <!-- CONTACT -->
          <td class="p-4 text-center text-xs text-gray-600">
            <p><%= order.phone %></p>
            <p class="text-gray-400"><%= order.email %></p>
          </td>

          <!-- ADDRESS -->
          <td class="p-4 text-xs text-gray-600 max-w-xs">
            <%= order.address %>
          </td>

          <!-- PAYMENT -->
          <td class="p-4 text-center text-xs text-gray-700">
            <%= order.payment %>
          </td>

          <!-- SIZE -->
          <td class="p-4 text-center">
            <span class="bg-gray-100 px-2 py-1 rounded text-xs">
              <%= order.size || "N/A" %>
            </span>
          </td>

          <!-- STATUS -->
          <td class="p-4 text-center">

            <span class="px-3 py-1 rounded-full text-xs font-medium
              <%= order.status === 'Placed' ? 'bg-yellow-100 text-yellow-700' : 
                  order.status === 'Shipped' ? 'bg-blue-100 text-blue-700' :
                  order.status === 'Out for Delivery' ? 'bg-purple-100 text-purple-700' :
                  order.status === 'Delivered' ? 'bg-green-100 text-green-700' :
                  order.status === 'Cancelled' ? 'bg-red-100 text-red-600' :
                  'bg-gray-100 text-gray-600' %>">

              <%= order.status %>

            </span>

          </td>

          <!-- ACTION -->
          <td class="p-4 text-center">

            <form action="/admin/update-status/<%= order._id %>" method="POST" class="flex flex-col gap-2 items-center">

              <select name="status" 
                class="border rounded px-2 py-1 text-xs focus:outline-none focus:ring-2 focus:ring-blue-400">

                <option <%= order.status === 'Placed' ? 'selected' : '' %>>Placed</option>
                <option <%= order.status === 'Shipped' ? 'selected' : '' %>>Shipped</option>
                <option <%= order.status === 'Out for Delivery' ? 'selected' : '' %>>Out for Delivery</option>
                <option <%= order.status === 'Delivered' ? 'selected' : '' %>>Delivered</option>
                <option <%= order.status === 'Cancelled' ? 'selected' : '' %>>Cancelled</option>

              </select>

              <button 
                class="bg-green-500 hover:bg-green-600 text-white px-3 py-1 rounded text-xs transition">
                Update
              </button>

            </form>

          </td>

        </tr>

      <% }) %>

      </tbody>

    </table>

  </div>

  <% } else { %>

    <!-- EMPTY STATE -->
    <div class="text-center mt-20">
      <h2 class="text-xl font-semibold text-gray-700">
        No orders found 😔
      </h2>
    </div>

  <% } %>

</div>

</body>
</html>