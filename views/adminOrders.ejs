<!DOCTYPE html>
<html>
<head>
  <title>Order Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 p-6">

<a href="/admin" class="bg-black text-white px-4 py-2 rounded">⬅ Back</a>

<div class="max-w-4xl mx-auto mt-6 bg-white p-6 rounded shadow">

  <h2 class="text-2xl font-bold mb-4">🧾 Order Details</h2>

  <!-- ORDER INFO -->
  <div class="mb-4">
    <p><b>Order ID:</b> <%= order._id %></p>
    <p><b>Status:</b> <%= order.status %></p>
    <p><b>Payment:</b> <%= order.paymentMethod %> (<%= order.paymentStatus %>)</p>
    <p><b>Date:</b> <%= new Date(order.createdAt).toDateString() %></p>
  </div>

  <!-- CUSTOMER -->
  <div class="mb-4">
    <h3 class="font-semibold text-lg mb-2">👤 Customer</h3>
    <p><%= order.name %></p>
    <p><%= order.phone %></p>
    <p><%= order.email %></p>
  </div>

  <!-- ADDRESS -->
  <div class="mb-4">
    <h3 class="font-semibold text-lg mb-2">📍 Address</h3>
    <p><%= order.address.house %>, <%= order.address.area %></p>
    <p><%= order.address.city %>, <%= order.address.state %></p>
    <p>Pincode: <%= order.address.pincode %></p>
  </div>

  <!-- ITEMS -->
  <div class="mb-4">
    <h3 class="font-semibold text-lg mb-2">📦 Items</h3>

    <% order.items.forEach(i => { %>

      <div class="flex gap-4 border p-3 rounded mb-2">

        <img src="<%= i.image %>" class="w-20 h-20 object-cover">

        <div>
          <p class="font-semibold"><%= i.name %></p>
          <p>₹ <%= i.price %></p>
          <p>Qty: <%= i.quantity %></p>

          <% if(i.size){ %>
            <p>Size: <%= i.size %></p>
          <% } %>

        </div>

      </div>

    <% }) %>

  </div>

  <!-- TOTAL -->
  <div class="text-right text-xl font-bold text-green-600">
    Total: ₹ <%= order.totalAmount %>
  </div>

</div>

</body>
</html>