<!DOCTYPE html>
<html>
<head>
  <title>Admin Orders</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold text-gray-800">
      📦 Admin Orders
    </h1>

    <span class="text-sm text-gray-500">
      Total Orders: <%= orders.length %>
    </span>
  </div>

  <!-- SEARCH -->
  <input 
    type="text" 
    id="orderSearch" 
    placeholder="🔍 Search orders..." 
    class="border p-3 mb-6 w-full rounded-lg shadow-sm focus:ring-2 focus:ring-blue-400"
  >

  <% if(orders && orders.length > 0){ %>

  <div class="space-y-6" id="orderList">

  <% orders.forEach(o => { %>

  <div class="bg-white rounded-xl shadow p-5 hover:shadow-lg transition order-card">

    <!-- HEADER -->
    <div class="flex flex-col md:flex-row justify-between gap-3 border-b pb-3 mb-3">

      <div>
        <p class="font-bold text-lg">Order ID: <%= o._id %></p>
        <p class="text-xs text-gray-500">
          <%= new Date(o.createdAt).toDateString() %>
        </p>
      </div>

      <!-- STATUS BADGE -->
      <span class="text-xs px-3 py-1 rounded-full font-semibold w-fit
        <%= o.status==='Delivered' ? 'bg-green-100 text-green-600' :
            o.status==='Cancelled' ? 'bg-red-100 text-red-600' :
            o.status==='Shipped' ? 'bg-blue-100 text-blue-600' :
            'bg-yellow-100 text-yellow-600' %>">
        <%= o.status %>
      </span>

    </div>

    <!-- PRODUCTS -->
    <div class="space-y-3">

      <% o.items.forEach(item => { %>

      <div class="flex gap-4 items-center border rounded-lg p-3">

        <img 
          src="<%= item.image || '/default.png' %>" 
          onerror="this.src='/default.png'"
          class="w-16 h-16 object-cover rounded"
        >

        <div class="flex-1">
          <p class="font-semibold"><%= item.name %></p>
          <p class="text-xs text-gray-500">
            Qty: <%= item.quantity %> | ₹ <%= item.price %>
          </p>
        </div>

        <p class="font-bold text-green-600">
          ₹ <%= item.price * item.quantity %>
        </p>

      </div>

      <% }) %>

    </div>

    <!-- DETAILS -->
    <div class="grid md:grid-cols-3 gap-4 mt-4 text-sm">

      <!-- ADDRESS -->
      <div>
        <p class="font-semibold mb-1">📍 Address</p>
        <p class="text-gray-600 text-xs">
          <%= o.address?.house %>, <%= o.address?.area %>,<br>
          <%= o.address?.city %>, <%= o.address?.state %> - <%= o.address?.pincode %>
        </p>
      </div>

      <!-- PAYMENT -->
      <div>
        <p class="font-semibold mb-1">💳 Payment</p>
        <p class="text-xs">
          Method: <%= o.paymentMethod %><br>
          Status: <span class="font-semibold"><%= o.paymentStatus %></span>
        </p>
      </div>

      <!-- TOTAL -->
      <div>
        <p class="font-semibold mb-1">💰 Total</p>
        <p class="text-green-600 font-bold text-lg">
          ₹ <%= o.totalAmount %>
        </p>
      </div>

    </div>

    <!-- ACTIONS -->
    <div class="flex flex-wrap gap-3 mt-4 items-center">

      <!-- STATUS UPDATE -->
      <form action="/admin/update-status/<%= o._id %>" method="POST" class="flex gap-2">

        <select name="status" class="border p-2 rounded">
          <option <%= o.status==='Placed'?'selected':'' %>>Placed</option>
          <option <%= o.status==='Shipped'?'selected':'' %>>Shipped</option>
          <option <%= o.status==='Out for Delivery'?'selected':'' %>>Out for Delivery</option>
          <option <%= o.status==='Delivered'?'selected':'' %>>Delivered</option>
          <option <%= o.status==='Cancelled'?'selected':'' %>>Cancelled</option>
        </select>

        <button class="bg-blue-500 hover:bg-blue-600 text-white px-3 rounded">
          Update
        </button>

      </form>

      <!-- INVOICE -->
      <a href="/download-invoice/<%= o._id %>"
        class="bg-purple-500 hover:bg-purple-600 text-white px-3 py-2 rounded">
        📄 Invoice
      </a>

    </div>

  </div>

  <% }) %>

  </div>

  <% } else { %>

  <!-- EMPTY STATE -->
  <div class="text-center mt-20">

    <img src="/empty.png" class="w-40 mx-auto mb-4 opacity-80">

    <h2 class="text-xl font-semibold text-gray-700">
      No Orders Found 😔
    </h2>

    <p class="text-gray-500 mt-2">
      No orders available in the system
    </p>

  </div>

  <% } %>

</div>

<!-- SEARCH SCRIPT -->
<script>
document.getElementById("orderSearch").addEventListener("input", function(){
  let val = this.value.toLowerCase();

  document.querySelectorAll(".order-card").forEach(card => {
    let text = card.innerText.toLowerCase();
    card.style.display = text.includes(val) ? "block" : "none";
  });
});
</script>

</body>
</html>