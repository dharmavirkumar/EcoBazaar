<nav class="bg-gray-900 text-white shadow-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">

    <!-- TOP BAR -->
    <div class="flex justify-between items-center h-16">

      <!-- LOGO -->
      <a href="/" class="text-2xl font-bold text-yellow-400">
        Lio<span class="text-white">Kart</span>
      </a>

      <!-- 🔍 DESKTOP SEARCH -->
      <div class="hidden md:flex flex-1 mx-6 max-w-xl relative">
        <form action="/search" method="GET" class="flex w-full">
          <input 
            type="text" 
            name="q" 
            placeholder="Search for products..." 
            class="w-full px-4 py-2 text-black rounded-l-lg focus:outline-none"
            onkeyup="liveSearch(this.value)"
          >
          <button class="bg-yellow-400 px-4 rounded-r-lg">🔍</button>
        </form>

        <div id="results" 
          class="absolute top-12 left-0 w-full bg-white text-black rounded shadow hidden z-50 max-h-80 overflow-y-auto">
        </div>
      </div>

      <!-- DESKTOP MENU -->
      <div class="hidden md:flex items-center gap-6">

        <a href="/" class="hover:text-yellow-400">Home</a>

        
        <a href="/category/fashion/All" class="hover:text-yellow-400">Men Wear</a>
        <a href="/category/women/All" class="hover:text-yellow-400">Women Wear</a>
        <a href="/category/electronics/All" class="hover:text-yellow-400">Electronics</a>
        <a href="/category/beauty/All" class="hover:text-yellow-400">Beauty</a>
        <a href="/category/accessories/All" class="hover:text-yellow-400">Accessories</a>

        <!-- 🛒 CART -->
        <a href="/cart" class="relative text-xl">
          🛒
          <% if(cartCount > 0){ %>
          <span class="absolute -top-2 -right-3 bg-red-500 text-xs px-2 rounded-full">
            <%= cartCount %>
          </span>
          <% } %>
        </a>

        <!-- 👤 USER -->
        <% if(user){ %>
        <div class="relative group">
          <button class="hover:text-yellow-400">👤 <%= user.name %></button>

          <div class="absolute right-0 hidden group-hover:block bg-white text-black rounded shadow w-40">
            <a href="/my-orders" class="block px-4 py-2 hover:bg-gray-100">Orders</a>
            <!-- <a href="/profile" class="block px-4 py-2 hover:bg-gray-100">Profile</a> -->
            
            <a href="/logout" class="block px-4 py-2 text-red-500 hover:bg-gray-100">Logout</a>
          </div>
        </div>
        <% } else { %>
        <a href="/login">Login</a>
        <% } %>

      </div>

      <!-- 📱 MOBILE ICONS -->
      <div class="flex items-center gap-4 md:hidden">

        <!-- SEARCH ICON -->
        <button onclick="toggleSearch()">🔍</button>

        <!-- CART -->
        <a href="/cart" class="relative text-xl">
          🛒
          <% if(cartCount > 0){ %>
          <span class="absolute -top-2 -right-3 bg-red-500 text-xs px-2 rounded-full">
            <%= cartCount %>
          </span>
          <% } %>
        </a>

        <!-- MENU -->
        <button onclick="toggleMenu()" class="text-2xl">☰</button>

      </div>

    </div>
  </div>

  <!-- 📱 MOBILE SEARCH -->
  <div id="mobileSearch" class="hidden md:hidden p-3 bg-gray-800">
    <form action="/search" method="GET" class="flex">
      <input 
        type="text" 
        name="q" 
        placeholder="Search..." 
        class="w-full px-3 py-2 text-black rounded-l"
      >
      <button class="bg-yellow-400 px-3 rounded-r">🔍</button>
    </form>
  </div>

  <!-- 📱 MOBILE MENU -->
  <div id="mobileMenu" class="hidden md:hidden bg-gray-800">

    <a href="/" class="block px-4 py-2 border-b border-gray-700">Home</a>
    <a href="/category/fashion/All" class="block px-4 py-2 border-b border-gray-700">Men Wear</a>
    <a href="/category/women/All" class="block px-4 py-2 border-b border-gray-700">Women Wear</a>
    <a href="/category/electronics/All" class="block px-4 py-2 border-b border-gray-700">Electronics</a>
    <a href="/category/beauty/All" class="block px-4 py-2 border-b border-gray-700">Beauty</a>
    <a href="/category/accessories/All" class="block px-4 py-2 border-b border-gray-700">Accessories</a>

    <% if(user){ %>
    <a href="/my-orders" class="block px-4 py-2 border-b border-gray-700">Orders</a>
    <!-- <a href="/profile" class="block px-4 py-2 border-b border-gray-700">Profile</a> -->
    <a href="/logout" class="block px-4 py-2 text-red-400">Logout</a>
    <% } else { %>
    <a href="/login" class="block px-4 py-2">Login</a>
    <% } %>

  </div>
</nav>
<script>
function toggleMenu(){
  document.getElementById("mobileMenu").classList.toggle("hidden");
}

function toggleSearch(){
  document.getElementById("mobileSearch").classList.toggle("hidden");
}

// CLOSE ON OUTSIDE CLICK
document.addEventListener("click", (e) => {
  if (!e.target.closest("nav")) {
    document.getElementById("mobileMenu").classList.add("hidden");
  }
});
</script>