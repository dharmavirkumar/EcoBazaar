<!-- JS -->
<script>
function toggleMenu(){
  document.getElementById("mobileMenu").classList.toggle("hidden");
}

// 🔍 LIVE SEARCH
async function liveSearch(value) {
  const resultsBox = document.getElementById("results");

  if (value.length < 2) {
    resultsBox.classList.add("hidden");
    return;
  }

  try {
    const res = await fetch(`/search?q=${value}`);
    const data = await res.text();

    resultsBox.innerHTML = data;
    resultsBox.classList.remove("hidden");

  } catch (err) {
    console.log(err);
  }
}
</script>
<script>
let timer;

// 🔥 LOAD SUGGESTIONS ON FOCUS
document.querySelector("input[name='q']").addEventListener("focus", loadSuggestions);

async function loadSuggestions() {
  const res = await fetch("/api/suggestions");
  const data = await res.json();

  const recent = JSON.parse(localStorage.getItem("recentSearches")) || [];

  const resultsBox = document.getElementById("results");

  resultsBox.innerHTML = `
    <div class="p-2 border-b">
      <p class="text-xs text-gray-400">Recent</p>
      ${recent.map(r => `<p class="p-1 hover:bg-gray-100 cursor-pointer" onclick="selectSearch('${r}')">${r}</p>`).join("")}
    </div>

    <div class="p-2">
      <p class="text-xs text-gray-400">Suggestions</p>
      ${data.map(s => `<p class="p-1 hover:bg-gray-100 cursor-pointer" onclick="selectSearch('${s}')">${s}</p>`).join("")}
    </div>
  `;

  resultsBox.classList.remove("hidden");
}

// 🔍 LIVE SEARCH
async function liveSearch(query) {
  const resultsBox = document.getElementById("results");

  clearTimeout(timer);

  if (!query) {
    loadSuggestions();
    return;
  }

  timer = setTimeout(async () => {
    const res = await fetch(`/api/search?q=${query}`);
    const data = await res.json();

    resultsBox.innerHTML = data.map(p => `
      <a href="/product/${p._id}" 
         onclick="saveRecent('${query}')"
         class="flex items-center gap-3 p-2 hover:bg-gray-100 border-b">

        <img src="${p.images?.[0] || '/default.png'}" class="w-10 h-10">

        <div>
          <p class="text-sm">${p.name}</p>
          <p class="text-green-600 text-sm">₹${p.finalPrice || p.price}</p>
        </div>
      </a>
    `).join("");

    resultsBox.classList.remove("hidden");

  }, 300);
}

// 💾 SAVE RECENT
function saveRecent(query) {
  let recent = JSON.parse(localStorage.getItem("recentSearches")) || [];

  if (!recent.includes(query)) {
    recent.unshift(query);
  }

  recent = recent.slice(0, 5);

  localStorage.setItem("recentSearches", JSON.stringify(recent));
}

// 👉 CLICK SELECT
function selectSearch(value) {
  document.querySelector("input[name='q']").value = value;
  window.location.href = `/search?q=${value}`;
}

// ❌ CLOSE DROPDOWN
document.addEventListener("click", (e) => {
  if (!e.target.closest(".relative")) {
    document.getElementById("results").classList.add("hidden");
  }
});
</script>