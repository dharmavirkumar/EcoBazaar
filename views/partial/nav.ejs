<nav class="bg-gray-900 text-white shadow-md">
  <div class="max-w-7xl mx-auto px-4">

    <div class="flex justify-between items-center h-16">

      <!-- LOGO -->
      <a href="/" class="text-2xl font-bold text-yellow-400">
        EcoBazaar
      </a>

      <!-- DESKTOP MENU -->
      <div class="hidden md:flex items-center gap-6">

        <!-- 🔍 SEARCH -->
        <div class="relative">
          <form action="/search" method="GET" class="flex items-center">
            <input 
              type="text" 
              name="q" 
              placeholder="Search products..." 
              class="px-4 py-2 text-black rounded-l-lg w-64 focus:outline-none"
              onkeyup="liveSearch(this.value)"
            >
            <button class="bg-yellow-400 text-black px-4 py-2 rounded-r-lg hover:bg-yellow-500">
              🔍
            </button>
          </form>

          <!-- LIVE RESULTS -->
          <div id="results" 
               class="absolute top-12 left-0 w-full bg-white text-black rounded shadow hidden z-50 max-h-60 overflow-y-auto">
          </div>
        </div>

        <!-- LINKS -->
        <a href="/" class="hover:text-yellow-400">Home</a>
        <a href="/men" class="hover:text-yellow-400">Fashion</a>
        <a href="/jewellery" class="hover:text-yellow-400">Jewellery</a>
        <a href="/beauty" class="hover:text-yellow-400">Beauty</a>
        <a href="/electronics" class="hover:text-yellow-400">Electronics</a>

        <!-- CART -->
        <a href="/cart" class="relative text-xl">
          🛒
          <% if(cartCount > 0){ %>
            <span class="absolute -top-2 -right-3 bg-red-500 text-white text-xs px-2 rounded-full">
              <%= cartCount %>
            </span>
          <% } %>
        </a>

        <!-- USER -->
        <% if(user){ %>
          <span class="text-sm">Hi, <%= user.name %></span>
          <a href="/my-orders" class="hover:text-yellow-400">Orders</a>
          <a href="/logout" class="bg-red-500 px-3 py-1 rounded hover:bg-red-600">
            Logout
          </a>
        <% } else { %>
          <a href="/login" class="hover:text-yellow-400">Login</a>
        <% } %>

      </div>

      <!-- MOBILE BUTTON -->
      <div class="md:hidden">
        <button onclick="toggleMenu()" class="text-2xl">
          ☰
        </button>
      </div>

    </div>
  </div>

  <!-- MOBILE MENU -->
  <div id="mobileMenu" class="hidden bg-gray-800 md:hidden">

    <!-- SEARCH MOBILE -->
    <div class="p-3">
      <form action="/search" method="GET" class="flex">
        <input 
          type="text" 
          name="q" 
          placeholder="Search..." 
          class="w-full px-3 py-2 text-black rounded-l"
        >
        <button class="bg-yellow-400 px-3 rounded-r">🔍</button>
      </form>
    </div>

    <a href="/" class="block px-4 py-2 hover:bg-gray-700">Home</a>
    <a href="/men" class="block px-4 py-2 hover:bg-gray-700">Fashion</a>
    <a href="/jewellery" class="block px-4 py-2 hover:bg-gray-700">Jewellery</a>
    <a href="/beauty" class="block px-4 py-2 hover:bg-gray-700">Beauty</a>
    <a href="/electronics" class="block px-4 py-2 hover:bg-gray-700">Electronics</a>

    <% if(user){ %>
      <a href="/my-orders" class="block px-4 py-2 hover:bg-gray-700">My Orders</a>
      <a href="/logout" class="block px-4 py-2 text-red-400 hover:bg-gray-700">Logout</a>
    <% } else { %>
      <a href="/login" class="block px-4 py-2 hover:bg-gray-700">Login</a>
    <% } %>

  </div>
</nav>

<!-- JS -->
<script>
function toggleMenu(){
  const menu = document.getElementById("mobileMenu");
  menu.classList.toggle("hidden");
}

// 🔍 LIVE SEARCH
async function liveSearch(value) {
  const resultsBox = document.getElementById("results");

  if (value.length < 2) {
    resultsBox.classList.add("hidden");
    return;
  }

  const res = await fetch(`/search?q=${value}`);
  const data = await res.text();

  resultsBox.innerHTML = data;
  resultsBox.classList.remove("hidden");
}
</script>