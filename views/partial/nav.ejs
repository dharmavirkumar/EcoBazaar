<nav class="bg-gray-900 text-white shadow-md sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4">

    <div class="flex justify-between items-center h-16">

      <!-- 🔥 LOGO -->
      <a href="/" class="text-2xl font-bold text-yellow-400 tracking-wide">
        EcoBazaar
      </a>

      <!-- 🔍 SEARCH (DESKTOP) -->
      <div class="hidden md:flex flex-1 mx-6 max-w-xl relative">
        <form action="/search" method="GET" class="flex w-full">
          <input 
            type="text" 
            name="q" 
            placeholder="Search for products..." 
            class="w-full px-4 py-2 text-black rounded-l-lg focus:outline-none"
            onkeyup="liveSearch(this.value)"
          >
          <button class="bg-yellow-400 text-black px-4 py-2 rounded-r-lg hover:bg-yellow-500">
            🔍
          </button>
        </form>

        <!-- LIVE SEARCH RESULTS -->
        <div id="results" 
          class="absolute top-12 left-0 w-full bg-white text-black rounded shadow hidden z-50 max-h-60 overflow-y-auto">
        </div>
      </div>

      <!-- DESKTOP MENU -->
      <div class="hidden md:flex items-center gap-6">

        <a href="/" class="hover:text-yellow-400">Home</a>
        <a href="/men" class="hover:text-yellow-400">Fashion</a>
        <a href="/jewellery" class="hover:text-yellow-400">Accessories</a>
        <a href="/beauty" class="hover:text-yellow-400">Beauty</a>
        <a href="/electronics" class="hover:text-yellow-400">Electronics</a>

        <!-- 🛒 CART -->
        <a href="/cart" class="relative text-xl hover:scale-110 transition">
          🛒
          <% if(cartCount > 0){ %>
            <span class="absolute -top-2 -right-3 bg-red-500 text-white text-xs px-2 rounded-full">
              <%= cartCount %>
            </span>
          <% } %>
        </a>

        <!-- 👤 USER DROPDOWN -->
        <% if(user){ %>
        <div class="relative group">
          <button class="flex items-center gap-2 hover:text-yellow-400">
            👤 <span><%= user.name %></span>
          </button>

          <!-- DROPDOWN -->
          <div class="absolute right-0 mt-2 w-48 bg-white text-black rounded shadow-lg hidden group-hover:block">
            <a href="/my-orders" class="block px-4 py-2 hover:bg-gray-100">
              📦 My Orders
            </a>
            <a href="/profile" class="block px-4 py-2 hover:bg-gray-100">
              👤 Profile
            </a>
            <a href="/logout" class="block px-4 py-2 text-red-500 hover:bg-gray-100">
              🚪 Logout
            </a>
          </div>
        </div>
        <% } else { %>
          <a href="/login" class="hover:text-yellow-400">Login</a>
        <% } %>

      </div>

      <!-- 📱 MOBILE BUTTON -->
      <div class="md:hidden">
        <button onclick="toggleMenu()" class="text-2xl">
          ☰
        </button>
      </div>

    </div>
  </div>

  <!-- 📱 MOBILE MENU -->
  <div id="mobileMenu" class="hidden bg-gray-800 md:hidden">

    <!-- SEARCH -->
    <div class="p-3">
      <form action="/search" method="GET" class="flex">
        <input 
          type="text" 
          name="q" 
          placeholder="Search..." 
          class="w-full px-3 py-2 text-black rounded-l"
        >
        <button class="bg-yellow-400 px-3 rounded-r">🔍</button>
      </form>
    </div>

    <a href="/" class="block px-4 py-2 hover:bg-gray-700">Home</a>
    <a href="/men" class="block px-4 py-2 hover:bg-gray-700">Fashion</a>
    <a href="/jewellery" class="block px-4 py-2 hover:bg-gray-700">Accessories</a>
    <a href="/beauty" class="block px-4 py-2 hover:bg-gray-700">Beauty</a>
    <a href="/electronics" class="block px-4 py-2 hover:bg-gray-700">Electronics</a>

    <% if(user){ %>
      <a href="/my-orders" class="block px-4 py-2 hover:bg-gray-700">📦 My Orders</a>
      <a href="/profile" class="block px-4 py-2 hover:bg-gray-700">👤 Profile</a>
      <a href="/logout" class="block px-4 py-2 text-red-400 hover:bg-gray-700">Logout</a>
    <% } else { %>
      <a href="/login" class="block px-4 py-2 hover:bg-gray-700">Login</a>
    <% } %>

  </div>
</nav>

<!-- JS -->
<script>
function toggleMenu(){
  document.getElementById("mobileMenu").classList.toggle("hidden");
}

// 🔍 LIVE SEARCH
async function liveSearch(value) {
  const resultsBox = document.getElementById("results");

  if (value.length < 2) {
    resultsBox.classList.add("hidden");
    return;
  }

  try {
    const res = await fetch(`/search?q=${value}`);
    const data = await res.text();

    resultsBox.innerHTML = data;
    resultsBox.classList.remove("hidden");

  } catch (err) {
    console.log(err);
  }
}
</script>