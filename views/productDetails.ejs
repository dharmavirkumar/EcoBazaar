<!DOCTYPE html>
<html>
<head>
  <title>Product Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔹 PRODUCT SECTION -->
<% if(product){ %>

<div class="max-w-7xl mx-auto p-6 grid md:grid-cols-2 gap-10 bg-white mt-10 rounded shadow">

  <!-- LEFT SIDE -->
  <div class="flex gap-4">

    <!-- 🔹 THUMBNAILS -->
    <div class="flex flex-col gap-3">

      <% if(product.images && product.images.length > 0){ %>
        <% product.images.slice(0,3).forEach(function(img, index){ %>
          <img 
            src="<%= img %>" 
            onclick="changeImage('<%= img %>')"
            class="w-20 h-20 object-cover rounded border cursor-pointer hover:border-blue-500 <%= index === 0 ? 'border-blue-500' : '' %>">
        <% }) %>
      <% } else if(product.image){ %>
        <img 
          src="<%= product.image %>" 
          class="w-20 h-20 object-cover rounded border">
      <% } %>

    </div>

    <!-- 🔹 MAIN IMAGE -->
    <div class="flex-1">
      <img 
        id="mainImage"
        src="<%= product.images?.[0] || product.image %>" 
        class="w-full h-[400px] object-cover rounded">
    </div>

  </div>

  <!-- RIGHT SIDE -->
  <div>

    <h1 class="text-2xl font-bold mb-3">
      <%= product.name %>
    </h1>

    <!-- PRICE -->
    <p class="text-3xl font-bold mb-2">
      <% if(product.discountType && product.discountType !== "none"){ %>

        <span class="text-gray-400 line-through mr-2">
          ₹ <%= product.price %>
        </span>

        <span class="text-green-600">
          ₹ <%= product.finalPrice %>
        </span>

        <span class="text-red-500 text-lg ml-2">
          <% if(product.discountType === "percentage"){ %>
            (<%= product.discountValue %>% OFF)
          <% } else { %>
            (₹ <%= product.discountValue %> OFF)
          <% } %>
        </span>

      <% } else { %>

        <span class="text-green-600">
          ₹ <%= product.price %>
        </span>

      <% } %>
    </p>

    <!-- RATING -->
    <p class="text-yellow-500 mb-3">
      ⭐ <%= avgRating ? avgRating.toFixed(1) : "No rating" %> / 5 
      (<%= reviews ? reviews.length : 0 %> reviews)
    </p>

    <!-- BUTTONS -->
    <div class="flex flex-col sm:flex-row gap-4 mt-6">

      <a href="/add-to-cart/<%= product._id %>"
        class="flex-1 flex items-center justify-center gap-3 border-2 border-purple-500 text-purple-600 py-3 rounded-xl font-semibold text-lg hover:bg-purple-50 transition active:scale-95">
        🛒 Add to Cart
      </a>

      <a href="/buy-now/<%= product._id %>"
        class="flex-1 flex items-center justify-center gap-3 bg-gradient-to-r from-purple-500 to-pink-500 text-white py-3 rounded-xl font-semibold text-lg hover:opacity-90 transition shadow-lg active:scale-95">
        » Buy Now
      </a>

    </div>

    <!-- DESCRIPTION -->
    <p class="text-gray-600 mt-6 mb-4">
      <%= product.description || "No description available" %>
    </p>

    <p class="text-green-600 font-semibold mb-4">
      🚚 Free Delivery
    </p>

    <!-- INFO -->
    <div class="bg-gray-100 p-4 rounded">
      <p><strong>Price:</strong> ₹ <%= product.price %></p>
      <p><strong>Delivery:</strong> 4-5 Days</p>
    </div>

  </div>

</div>

<% } else { %>

<p class="text-center mt-10 text-red-500 text-xl">Product not found 😔</p>

<% } %>


<!-- 🔥 SIMILAR PRODUCTS -->
<div class="max-w-7xl mx-auto mt-10">

<h2 class="text-2xl font-bold mb-6">Similar Products 🔥</h2>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

<% if(similarProducts && similarProducts.length > 0){ %>

  <% similarProducts.forEach(item => { %>

    <div class="bg-white p-4 rounded shadow hover:shadow-lg transition">

      <a href="/product/<%= item._id %>">

        <img 
        src="<%= item.images && item.images.length > 0 
                ? item.images[0] 
                : (item.image && item.image.startsWith('http') 
                    ? item.image 
                    : '/uploads/' + item.image) %>" 
        class="w-full h-40 object-cover">

      </a>

      <h3 class="mt-3 font-semibold">
        <%= item.name.substring(0, 40) %>...
      </h3>

      <p class="text-green-600 font-bold">₹ <%= item.price %></p>

      <a href="/product/<%= item._id %>" 
      class="block mt-2 bg-blue-500 text-white text-center py-1 rounded hover:bg-blue-600">
        View
      </a>

    </div>

  <% }) %>

<% } else { %>

<p>No similar products found</p>

<% } %>

</div>

</div>


<!-- ⭐ REVIEWS -->
<div class="max-w-5xl mx-auto mt-10">

<h2 class="text-xl font-bold mb-4">Customer Reviews</h2>

<% if(reviews && reviews.length > 0){ %>

  <% reviews.forEach(r => { %>

    <div class="bg-white p-4 mb-3 rounded shadow">
      <h3 class="font-semibold"><%= r.name %></h3>
      <p class="text-yellow-500">⭐ <%= r.rating %> / 5</p>
      <p class="text-gray-600"><%= r.comment %></p>
    </div>

  <% }) %>

<% } else { %>

  <p>No reviews yet 😔</p>

<% } %>

</div>


<!-- ✍️ ADD REVIEW -->
<div class="max-w-5xl mx-auto mt-10 bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Leave a Review ⭐</h2>

<form action="/add-review" method="POST">

<input type="hidden" name="productId" value="<%= product._id %>">

<input type="text" name="name" placeholder="Your Name"
class="w-full border p-2 mb-3 rounded" required>

<select name="rating" class="w-full border p-2 mb-3 rounded" required>
  <option value="">Select Rating</option>
  <option value="5">⭐⭐⭐⭐⭐ (5)</option>
  <option value="4">⭐⭐⭐⭐ (4)</option>
  <option value="3">⭐⭐⭐ (3)</option>
  <option value="2">⭐⭐ (2)</option>
  <option value="1">⭐ (1)</option>
</select>

<textarea name="comment" placeholder="Write your review..."
class="w-full border p-2 mb-3 rounded"></textarea>

<button class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
Submit Review
</button>

</form>

</div>


<%- include("partial/footer") %>

<script>
function changeImage(src) {
  document.getElementById("mainImage").src = src;
}
</script>

</body>
</html>