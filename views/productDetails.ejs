<!DOCTYPE html>
<html>
<head>
  <title>Product Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<% if(product){ %>

<div class="max-w-7xl mx-auto p-4 md:p-6 grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10 bg-white mt-6 md:mt-10 rounded shadow">

  <!-- LEFT SIDE -->
  <div class="flex flex-col md:flex-row gap-4">

    <!-- THUMBNAILS -->
    <div class="flex md:flex-col gap-2 overflow-x-auto md:overflow-visible">
      <% if(product.images && product.images.length > 0){ %>
        <% product.images.slice(0,4).forEach(function(img, index){ %>
          <img 
            src="<%= img %>" 
            onclick="changeImage('<%= img %>')"
            class="w-16 h-16 md:w-20 md:h-20 object-cover rounded border cursor-pointer hover:border-blue-500 <%= index === 0 ? 'border-blue-500' : '' %>">
        <% }) %>
      <% } %>
    </div>

    <!-- MAIN IMAGE -->
    <div class="flex-1">
      <img 
        id="mainImage"
        src="<%= product.images?.[0] || product.image %>" 
        class="w-full h-72 md:h-[500px] object-cover rounded">
    </div>

  </div>

  <!-- RIGHT SIDE -->
  <div>

    <h1 class="text-xl md:text-2xl font-bold mb-2 md:mb-3">
      <%= product.name %>
    </h1>

    <!-- PRICE -->
    <p class="text-2xl md:text-3xl font-bold mb-2">

      <% if(product.discountType && product.discountType !== "none"){ %>

        <span class="text-gray-400 line-through mr-2 text-lg md:text-xl">
          ₹ <%= product.price %>
        </span>

        <span class="text-green-600">
          ₹ <%= product.finalPrice %>
        </span>

        <span class="text-red-500 text-sm md:text-lg ml-2">
          <% if(product.discountType === "percentage"){ %>
            (<%= product.discountValue %>% OFF)
          <% } else { %>
            (₹ <%= product.discountValue %> OFF)
          <% } %>
        </span>

      <% } else { %>

        <span class="text-green-600">
          ₹ <%= product.price %>
        </span>

      <% } %>

    </p>

    <!-- RATING -->
    <p class="text-yellow-500 text-sm md:text-base mb-3">
      ⭐ <%= avgRating ? avgRating.toFixed(1) : "No rating" %> / 5 
      (<%= reviews ? reviews.length : 0 %> reviews)
    </p>

    <!-- BUTTONS -->
    <div class="flex flex-col sm:flex-row gap-3 mt-4 md:mt-6">

      <a href="/add-to-cart/<%= product._id %>"
        class="flex-1 flex items-center justify-center gap-2 border-2 border-purple-500 text-purple-600 py-3 rounded-lg font-semibold hover:bg-purple-50 transition">
        🛒 Add to Cart
      </a>

      <a href="/buy-now/<%= product._id %>"
        class="flex-1 flex items-center justify-center gap-2 bg-gradient-to-r from-purple-500 to-pink-500 text-white py-3 rounded-lg font-semibold hover:opacity-90 transition">
        Buy Now
      </a>

    </div>

    <!-- DESCRIPTION -->
    <p class="text-gray-600 mt-4 md:mt-6 text-sm md:text-base">
      <%= product.description || "No description available" %>
    </p>

    <p class="text-green-600 font-semibold mt-2">
      🚚 Free Delivery
    </p>

    <!-- INFO -->
    <div class="bg-gray-100 p-4 rounded-xl mt-4">
      <p><strong>Price:</strong> ₹ <%= product.price %></p>
      <p><strong>Delivery:</strong> 4-5 Days</p>
    </div>

    <!-- ICON FEATURES -->
    <div class="mt-6 bg-gray-200 rounded-xl p-4 flex justify-between text-center">

      <div class="flex-1 flex flex-col items-center">
        <img src="https://cdn-icons-png.flaticon.com/512/3523/3523887.png" class="w-6 mb-2">
        <p class="text-sm">Lowest Price</p>
      </div>

      <div class="flex-1 flex flex-col items-center">
        <img src="https://cdn-icons-png.flaticon.com/512/2331/2331941.png" class="w-6 mb-2">
        <p class="text-sm">COD Available</p>
      </div>

    </div>

  </div>

</div>

<% } %>

<!-- SIMILAR PRODUCTS -->
<div class="max-w-7xl mx-auto mt-10 px-4">

<h2 class="text-xl md:text-2xl font-bold mb-4">Similar Products 🔥</h2>

<div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">

<% if(similarProducts && similarProducts.length > 0){ %>

  <% similarProducts.forEach(item => { %>

    <div class="bg-white p-3 md:p-4 rounded shadow">

      <a href="/product/<%= item._id %>">
        <img 
        src="<%= item.images?.[0] || '/default.png' %>" 
        class="w-full h-32 md:h-40 object-cover rounded">
      </a>

      <h3 class="mt-2 text-sm md:text-base font-semibold">
        <%= item.name.substring(0, 30) %>...
      </h3>

      <p class="text-green-600 font-bold text-sm md:text-base">₹ <%= item.price %></p>

    </div>

  <% }) %>

<% } %>

</div>

</div>

<!-- REVIEWS -->
<div class="max-w-5xl mx-auto mt-10 px-4">

<h2 class="text-lg md:text-xl font-bold mb-4">Customer Reviews</h2>

<% if(reviews && reviews.length > 0){ %>

  <% reviews.forEach(r => { %>

    <div class="bg-white p-4 mb-3 rounded shadow">
      <h3 class="font-semibold"><%= r.name %></h3>
      <p class="text-yellow-500">⭐ <%= r.rating %> / 5</p>
      <p class="text-gray-600 text-sm"><%= r.comment %></p>
    </div>

  <% }) %>

<% } else { %>

  <p>No reviews yet 😔</p>

<% } %>

</div>

<!-- ADD REVIEW -->
<div class="max-w-5xl mx-auto mt-10 bg-white p-4 md:p-6 rounded shadow">

<h2 class="text-lg md:text-xl font-bold mb-4">Leave a Review ⭐</h2>

<form action="/add-review" method="POST">

<input type="hidden" name="productId" value="<%= product._id %>">

<input type="text" name="name" placeholder="Your Name"
class="w-full border p-2 mb-3 rounded text-sm" required>

<select name="rating" class="w-full border p-2 mb-3 rounded text-sm" required>
  <option value="">Select Rating</option>
  <option value="5">⭐⭐⭐⭐⭐</option>
  <option value="4">⭐⭐⭐⭐</option>
  <option value="3">⭐⭐⭐</option>
  <option value="2">⭐⭐</option>
  <option value="1">⭐</option>
</select>

<textarea name="comment" placeholder="Write your review..."
class="w-full border p-2 mb-3 rounded text-sm"></textarea>

<button class="bg-blue-500 text-white px-4 py-2 rounded w-full md:w-auto">
Submit Review
</button>

</form>

</div>

<%- include("partial/footer") %>

<script>
function changeImage(src) {
  document.getElementById("mainImage").src = src;
}
</script>

</body>
</html>