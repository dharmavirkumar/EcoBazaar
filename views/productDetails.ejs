<!DOCTYPE html>
<html>
<head>
  <title>Product Details</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    .thumb.active { border: 2px solid #ff3f6c; }
    .size-btn.active {
      border: 2px solid #ff3f6c;
      color: #ff3f6c;
      font-weight: 600;
      background: #fff0f3;
    }
  </style>
</head>

<body class="bg-gray-50">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto mt-6 grid grid-cols-1 lg:grid-cols-2 gap-10 bg-white p-6 rounded-lg shadow">

  <!-- LEFT IMAGE SECTION -->
  <div class="flex gap-4">

    <!-- THUMBNAILS -->
    <div class="flex flex-col gap-2">
      <% product.images?.forEach((img,i)=>{ %>
        <img src="<%= img %>"
        onclick="changeImage('<%= img %>', this)"
        class="thumb w-16 h-16 object-cover rounded cursor-pointer <%= i===0?'active':'' %>">
      <% }) %>
    </div>

    <!-- MAIN IMAGE -->
    <div class="flex-1">
      <img id="mainImage"
      src="<%= product.images?.[0] || '/default.png' %>"
      class="w-full h-[450px] object-contain rounded">
    </div>

  </div>

  <!-- RIGHT CONTENT -->
  <div>

    <h1 class="text-2xl font-semibold"><%= product.name %></h1>

    <!-- RATING -->
    <div class="flex items-center gap-2 mt-2">
      <span class="bg-green-600 text-white px-2 py-1 text-xs rounded">
        <%= avgRating?.toFixed(1) || 0 %> ⭐
      </span>
      <span class="text-gray-500 text-sm">
        (<%= reviews?.length || 0 %> Reviews)
      </span>
    </div>

    <!-- PRICE -->
    <div class="mt-4 border-b pb-4">

      <% if(product.discountType && product.discountType !== 'none'){ %>

        <p class="text-gray-400 line-through">₹ <%= product.price %></p>

        <div class="flex items-center gap-3">
          <p id="priceBox" class="text-3xl font-bold text-gray-900">
            ₹ <%= product.finalPrice %>
          </p>
          <span class="text-pink-500 font-semibold">
            <%= Math.round(((product.price-product.finalPrice)/product.price)*100) %>% OFF
          </span>
        </div>

      <% } else { %>

        <p id="priceBox" class="text-3xl font-bold text-gray-900">
          ₹ <%= product.price %>
        </p>

      <% } %>

    </div>

    <!-- SIZE -->
    <div class="mt-5">
      <h3 class="font-semibold mb-2">Select Size</h3>

      <div class="flex gap-3 flex-wrap">

        <% product.sizes?.forEach(item => { %>

          <button 
          onclick="selectSize('<%= item.size %>', this)"
          <%= item.stock === 0 ? 'disabled' : '' %>
          class="size-btn w-14 h-14 border rounded-full text-sm 
          hover:border-pink-500
          <%= item.stock===0?'opacity-30 cursor-not-allowed':'' %>">

          <%= item.size %>

          </button>

        <% }) %>

      </div>

      <p id="sizeError" class="text-red-500 text-sm mt-2 hidden">
        Please select a size
      </p>
    </div>

    <!-- BUTTONS -->
    <div class="flex gap-4 mt-6">

      <button onclick="addToCart()"
      class="flex-1 bg-pink-500 text-white py-3 rounded font-semibold hover:bg-pink-600">
        🛒 ADD TO BAG
      </button>

      <button onclick="buyNow()"
      class="flex-1 border border-gray-400 py-3 rounded font-semibold hover:border-black">
        ⚡ BUY NOW
      </button>

    </div>

    <!-- DELIVERY -->
    <div class="mt-6 text-sm space-y-1 border-t pt-4">
      <p>🚚 Free Delivery</p>
      <p>💰 Cash on Delivery</p>
      <p>🔁 7 Days Return</p>
    </div>

    <!-- HIGHLIGHTS -->
    <div class="mt-6 bg-gray-50 p-4 rounded">
      <h2 class="font-semibold mb-2">Highlights</h2>
      <ul class="text-sm text-gray-600 list-disc pl-4">
        <% product.highlights?.forEach(h => { %>
          <li><%= h %></li>
        <% }) %>
      </ul>
    </div>
      <h3 class="font-bold mt-6 mb-3">Specifications</h3>

  <div class="divide-y">
    <% Object.keys(product.specifications||{}).forEach(key => { %>
      <div class="flex justify-between py-2 text-sm">
        <span><%= key %></span>
        <span><%= product.specifications[key] %></span>
      </div>
    <% }) %>
  </div>
  </div>
</div>

<!-- DESCRIPTION -->
<div class="max-w-7xl mx-auto mt-6 bg-white p-6 rounded shadow">
  <h3 class="font-bold mb-3">Description</h3>
  <div class="text-gray-700 text-sm"><%- product.description %></div>

  
</div>

<!-- SIMILAR PRODUCTS -->
<div class="max-w-7xl mx-auto mt-10">

  <h2 class="text-xl font-bold mb-4">Similar Products</h2>

  <div class="grid grid-cols-2 md:grid-cols-5 gap-4">

    <% similarProducts.forEach(item => { %>

    <a href="/product/<%= item._id %>" class="bg-white p-2 rounded shadow hover:shadow-lg transition">

      <img src="<%= item.images?.[0] || '/default.png' %>"
      class="w-full h-40 object-contain">

      <p class="text-sm mt-2 line-clamp-2"><%= item.name %></p>

      <p class="text-pink-500 font-bold">₹ <%= item.price %></p>

    </a>

    <% }) %>

  </div>

</div>

<!-- REVIEWS -->
<div class="max-w-5xl mx-auto mt-10">

  <h2 class="font-bold mb-3">Customer Reviews</h2>

  <% if(reviews.length > 0){ %>
    <% reviews.forEach(r => { %>
      <div class="bg-white p-3 mb-2 rounded shadow">
        <p class="font-semibold"><%= r.name %></p>
        <p class="text-green-600 text-sm">⭐ <%= r.rating %></p>
        <p class="text-gray-600 text-sm"><%= r.comment %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet</p>
  <% } %>

</div>

<!-- MOBILE BAR -->
<div class="fixed bottom-0 w-full bg-white p-3 flex gap-3 md:hidden">

  <button onclick="addToCart()" class="flex-1 border border-pink-500 text-pink-500 py-2 rounded">
    Add
  </button>

  <button onclick="buyNow()" class="flex-1 bg-pink-500 text-white py-2 rounded">
    Buy
  </button>

</div>

<%- include("partial/footer") %>

<script>
let selectedSize = null;

function changeImage(src, el){
  document.getElementById('mainImage').src = src;
  document.querySelectorAll('.thumb').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}

function selectSize(size, el){
  selectedSize = size;
  document.querySelectorAll('.size-btn').forEach(btn=>btn.classList.remove('active'));
  el.classList.add('active');
  document.getElementById("sizeError").classList.add("hidden");

  const sizes = <%- JSON.stringify(product.sizes||[]) %>;
  const s = sizes.find(x=>x.size==size);
  if(s?.price){
    document.getElementById("priceBox").innerText = "₹ "+s.price;
  }
}

function validateSize(){
  if(!selectedSize){
    document.getElementById("sizeError").classList.remove("hidden");
    return false;
  }
  return true;
}

function addToCart(){
  if(validateSize()){
    window.location=`/add-to-cart/<%= product._id %>?size=${selectedSize}`;
  }
}

function buyNow(){
  if(validateSize()){
    window.location=`/buy-now/<%= product._id %>?size=${selectedSize}`;
  }
}
</script>

</body>
</html>