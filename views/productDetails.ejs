<!DOCTYPE html>
<html>
<head>
  <title>Product Details</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>

  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.css"/>
  <script src="https://cdn.jsdelivr.net/npm/swiper/swiper-bundle.min.js"></script>
</head>

<body class="bg-gray-50">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto mt-6 grid grid-cols-1 lg:grid-cols-2 gap-10 bg-white p-6 rounded-lg shadow">

  <!-- IMAGE SLIDER -->
  <div class="swiper mySwiper w-full">
    <div class="swiper-wrapper">
      <% product.images?.forEach(img => { %>
        <div class="swiper-slide">
          <img src="<%= img %>" class="w-full h-[450px] object-contain rounded">
        </div>
      <% }) %>
    </div>

    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
    <div class="swiper-pagination"></div>
  </div>

  <!-- RIGHT CONTENT -->
  <div>

    <h1 class="text-2xl font-semibold"><%= product.name %></h1>

    <!-- RATING -->
    <div class="flex items-center gap-2 mt-2">
      <span class="bg-green-600 text-white px-2 py-1 text-xs rounded">
        <%= avgRating?.toFixed(1) || 0 %> ⭐
      </span>
      <span class="text-gray-500 text-sm">
        (<%= reviews?.length || 0 %> Reviews)
      </span>
    </div>

    <!-- PRICE -->
    <div class="mt-4 border-b pb-4">
      <% if(product.discountType && product.discountType !== 'none'){ %>

        <p class="text-gray-400 line-through">
          ₹ <%= product.price.toFixed(2) %>
        </p>

        <div class="flex items-center gap-3">
          <p class="text-3xl font-bold text-gray-900">
            ₹ <%= product.finalPrice.toFixed(2) %>
          </p>

          <span class="text-pink-500 font-semibold">
            <%= Math.round(((product.price - product.finalPrice) / product.price) * 100) %>% OFF
          </span>
        </div>

      <% } else { %>

        <p class="text-3xl font-bold text-gray-900">
          ₹ <%= product.price.toFixed(2) %>
        </p>

      <% } %>
    </div>

    <!-- BUTTONS -->
    <div class="flex gap-4 mt-6">
      <button onclick="addToCart()"
        class="flex-1 bg-pink-500 text-white py-3 rounded font-semibold hover:bg-pink-600">
        🛒 ADD TO BAG
      </button>

      <button onclick="buyNow()"
        class="flex-1 border border-gray-400 py-3 rounded font-semibold hover:border-black">
        ⚡ BUY NOW
      </button>
    </div>

    <!-- DELIVERY -->
    <div class="mt-6 text-sm space-y-1 border-t pt-4">
      <p>🚚 Free Delivery</p>
      <p>💰 Cash on Delivery</p>
      <p>🔁 7 Days Return</p>
      <p>📞 24/7 Customer Care</p>
    </div>

    <!-- PINCODE -->
    <div class="bg-white p-4 rounded-xl shadow mt-4">

      <h2 class="font-bold text-lg mb-3">Delivery details</h2>

      <div class="flex gap-2 mb-3">
        <input id="pincode"
          placeholder="Enter pincode"
          class="border p-2 flex-1 rounded">

        <button onclick="checkDelivery()"
          class="bg-blue-500 text-white px-4 rounded">
          Check
        </button>
      </div>

      <div id="result" class="text-sm"></div>

    </div>

    <!-- HIGHLIGHTS -->
    <div class="mt-6 bg-gray-50 p-4 rounded">
      <h2 class="font-semibold mb-2">Highlights</h2>
      <ul class="text-sm text-gray-600 list-disc pl-4">
        <% (product.highlights || []).forEach(h => { %>
          <li><%= h %></li>
        <% }) %>
      </ul>
    </div>

    <!-- SPECIFICATIONS -->
    <h3 class="font-bold mt-6 mb-3">Specifications</h3>
    <div class="divide-y">
      <% Object.keys(product.specifications || {}).forEach(key => { %>
        <div class="flex justify-between py-2 text-sm">
          <span><%= key %></span>
          <span><%= product.specifications[key] %></span>
        </div>
      <% }) %>
    </div>

  </div>
</div>

<!-- DESCRIPTION -->
<div class="max-w-7xl mx-auto mt-6 bg-white p-6 rounded shadow">
  <h3 class="font-bold mb-3">Description</h3>
  <div class="text-gray-700 text-sm"><%- product.description %></div>
</div>

<!-- SIMILAR -->
<div class="max-w-7xl mx-auto mt-10">
  <h2 class="text-xl font-bold mb-4">Similar Products</h2>

  <% if(similarProducts && similarProducts.length > 0){ %>

  <div class="swiper similarSwiper">
    <div class="swiper-wrapper">

      <% similarProducts.forEach(item => { %>
        <div class="swiper-slide">
          <div class="bg-white p-3 rounded shadow">

            <a href="/product/<%= item._id %>">
              <img src="<%= item.images?.[0] || '/default.png' %>"
                class="w-full h-40 object-contain">
            </a>

            <p class="text-sm mt-2 font-medium"><%= item.name %></p>

            <div class="mt-1 font-bold text-pink-500">
              ₹ <%= item.finalPrice || item.price %>
            </div>

          </div>
        </div>
      <% }) %>

    </div>

    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>
  </div>

  <% } %>
</div>

<!-- REVIEWS -->
<div class="max-w-5xl mx-auto mt-10">
  <h2 class="font-bold mb-3">Customer Reviews</h2>

  <% (reviews || []).forEach(r => { %>
    <div class="bg-white p-3 mb-2 rounded shadow">
      <p class="font-semibold"><%= r.name %></p>
      <p class="text-green-600 text-sm">⭐ <%= r.rating %></p>
      <p class="text-gray-600 text-sm"><%= r.comment %></p>
    </div>
  <% }) %>
</div>

<!-- SCRIPTS -->
<script>
function addToCart(){
  window.location = `/add-to-cart/<%= product._id %>`;
}

function buyNow(){
  window.location = `/buy-now/<%= product._id %>`;
}

async function checkDelivery(){
  const pin = document.getElementById("pincode").value;
  const res = await fetch(`/check-delivery?pincode=${pin}`);
  const data = await res.json();

  document.getElementById("result").innerHTML =
    data.available
      ? `🚚 Delivery by ${data.deliveryDate}`
      : `❌ Not available`;
}
</script>

<script>
new Swiper(".mySwiper", {
  loop: true,
  pagination: { el: ".swiper-pagination", clickable: true },
  navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" }
});

new Swiper(".similarSwiper", {
  slidesPerView: 2,
  spaceBetween: 10,
  breakpoints: {
    640: { slidesPerView: 3 },
    1024: { slidesPerView: 5 }
  }
});
</script>

</body>
</html>