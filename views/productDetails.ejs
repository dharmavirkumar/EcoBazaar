<!-- SIMILAR PRODUCTS SLIDER -->
<div class="max-w-7xl mx-auto mt-10">
  <h2 class="text-xl font-bold mb-4">Similar Products</h2>

  <% if(similarProducts && similarProducts.length > 0){ %>

  <div class="swiper similarSwiper">

    <div class="swiper-wrapper">

      <% similarProducts.forEach(item => { %>

        <div class="swiper-slide">

          <div class="bg-white p-3 rounded-xl shadow hover:shadow-lg transition group relative">

            <!-- 🔥 DISCOUNT BADGE -->
            <% if(item.finalPrice && item.price){ 
              let discount = Math.round(((item.price - item.finalPrice) / item.price) * 100);
              if(discount > 0){ %>

              <span class="absolute top-2 left-2 bg-pink-500 text-white text-xs px-2 py-1 rounded">
                <%= discount %>% OFF
              </span>

            <% } } %>

            <!-- ✅ IMAGE (CLICKABLE) -->
            <a href="/product/<%= item._id %>">
              <div class="overflow-hidden rounded">
                <img src="<%= item.images?.[0] || '/default.png' %>" 
                     class="w-full h-40 object-contain group-hover:scale-105 transition duration-300 cursor-pointer">
              </div>
            </a>

            <!-- NAME -->
            <p class="text-sm mt-2 line-clamp-2 font-medium">
              <%= item.name %>
            </p>

            <!-- ⭐ RATING -->
            <!-- <div class="flex items-center gap-1 mt-1">
              <span class="bg-green-600 text-white text-xs px-2 py-0.5 rounded">
                <%= item.avgRating ? item.avgRating.toFixed(1) : "0.0" %> ⭐
              </span>

              <span class="text-gray-500 text-xs">
                (<%= item.reviewCount || 0 %>)
              </span>
            </div> -->

            <!-- PRICE -->
            <div class="mt-1">
              <% if(item.finalPrice && item.finalPrice < item.price){ %>

                <span class="text-pink-500 font-bold">
                  ₹ <%= item.finalPrice %>
                </span>

                <span class="text-gray-400 line-through text-xs ml-1">
                  ₹ <%= item.price %>
                </span>

              <% } else { %>

                <span class="text-pink-500 font-bold">
                  ₹ <%= item.price %>
                </span>

              <% } %>
            </div>

            <!-- BUTTON -->
            <a href="/product/<%= item._id %>" 
               class="block mt-3 text-center bg-black text-white text-xs py-1 rounded hover:bg-gray-800">
              View
            </a>

          </div>

        </div>

      <% }) %>

    </div>

    <!-- ARROWS -->
    <div class="swiper-button-next"></div>
    <div class="swiper-button-prev"></div>

  </div>

  <% } else { %>

    <p class="text-gray-500">No similar products found</p>

  <% } %>
</div>


<!-- REVIEWS -->
<div class="max-w-5xl mx-auto mt-10">

  <h2 class="font-bold mb-3">Customer Reviews</h2>

  <% if(reviews.length > 0){ %>

    <div id="reviewContainer">

      <% reviews.forEach((r, i) => { %>

        <div class="review-item bg-white p-3 mb-2 rounded shadow 
        <%= i >= 4 ? 'hidden extra-review' : '' %>">

          <p class="font-semibold"><%= r.name %></p>
          <p class="text-green-600 text-sm">⭐ <%= r.rating %></p>
          <p class="text-gray-600 text-sm"><%= r.comment %></p>

        </div>

      <% }) %>

    </div>

    <!-- SHOW MORE BUTTON -->
    <% if(reviews.length > 4){ %>
      <button id="showMoreBtn"
        class="mt-4 text-pink-500 font-semibold">
        Show More
      </button>
    <% } %>

  <% } else { %>
    <p>No reviews yet</p>
  <% } %>

</div>

