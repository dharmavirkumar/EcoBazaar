 <!-- SCRIPTS  -->
  <script>
async function checkDelivery(){
  const pin = document.getElementById("pincode").value.trim();
  const result = document.getElementById("result");

  if(!pin){
    result.innerHTML = `
      <div class="bg-red-100 text-red-600 p-2 rounded">
        ⚠️ Please enter pincode
      </div>
    `;
    return;
  }

  // Loading state
  result.innerHTML = `
    <div class="text-gray-500">Checking delivery...</div>
  `;

  try{
    const res = await fetch(`/check-delivery?pincode=${pin}`);
    const data = await res.json();

    if(data.available){
      result.innerHTML = `
        <div class="bg-green-100 text-green-700 p-3 rounded flex justify-between items-center">
          <span>🚚 Delivery by <b>${data.deliveryDate}</b></span>
          <span class="text-xs text-green-600 font-semibold">FREE</span>
        </div>
      `;
    } else {
      result.innerHTML = `
        <div class="bg-red-100 text-red-600 p-2 rounded">
          ❌ Delivery not available for this pincode
        </div>
      `;
    }

  } catch(err){
    result.innerHTML = `
      <div class="bg-red-100 text-red-600 p-2 rounded">
        ⚠️ Server error, try again
      </div>
    `;
  }
}
</script>
<script>
let selectedSize = null;

const sizeErrorEl = document.getElementById("sizeError");
const priceBoxEl = document.getElementById("priceBox");

const sizes = <%- JSON.stringify(product.sizes || []) %>;
const hasSize = <%- JSON.stringify(showSize) %>;



function addToCart(){
  if(!selectedSize){
    alert("Please select size");
    return;
  }
  window.location = `/add-to-cart/<%= product._id %>?size=${selectedSize}`;
}

function buyNow(){
  if(!selectedSize){
    alert("Please select size");
    return;
  }
  window.location = `/buy-now/<%= product._id %>?size=${selectedSize}`;
}
document.addEventListener("DOMContentLoaded", () => {

  const sizeButtons = document.querySelectorAll(".size-btn");
  const selectedInput = document.getElementById("selectedSize");

  let selectedSize = null;

  sizeButtons.forEach(btn => {
    btn.addEventListener("click", () => {

      sizeButtons.forEach(b => b.classList.remove("active"));

      btn.classList.add("active");

      selectedSize = btn.dataset.size;

      if (selectedInput) {
        selectedInput.value = selectedSize;
      }
    });
  });

  window.addToCart = function () {
    if (!selectedSize) {
      alert("Please select size");
      return;
    }
    window.location = `/add-to-cart/<%= product._id %>?size=${selectedSize}`;
  };

  window.buyNow = function () {
    if (!selectedSize) {
      alert("Please select size");
      return;
    }
    window.location = `/buy-now/<%= product._id %>?size=${selectedSize}`;
  };

});
</script>

<script>
new Swiper(".mySwiper", {
  loop: true,
  spaceBetween: 10,
  pagination: { el: ".swiper-pagination", clickable: true },
  navigation: { nextEl: ".swiper-button-next", prevEl: ".swiper-button-prev" }
});
</script>
<script>
let expanded = false;

const btn = document.getElementById("showMoreBtn");

if(btn){
  btn.addEventListener("click", () => {

    const extraReviews = document.querySelectorAll(".extra-review");

    extraReviews.forEach(el => {
      el.classList.toggle("hidden");
    });

    expanded = !expanded;
    btn.innerText = expanded ? "Show Less" : "Show More";
  });
}
</script>
<script>
new Swiper(".similarSwiper", {
  slidesPerView: 2,
  spaceBetween: 10,
  loop: true,

  autoplay: {
    delay: 2500,
    disableOnInteraction: false,
  },

  navigation: {
    nextEl: ".swiper-button-next",
    prevEl: ".swiper-button-prev",
  },

  breakpoints: {
    640: { slidesPerView: 3 },
    768: { slidesPerView: 4 },
    1024: { slidesPerView: 5 }
  }
});
</script>
