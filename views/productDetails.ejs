<!DOCTYPE html>
<html>
<head>
  <title>Product Details</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- NAVBAR -->
<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto mt-6 grid grid-cols-1 lg:grid-cols-2 gap-8 bg-white p-4 md:p-6 rounded shadow">

  <!-- LEFT: IMAGE + THUMBNAILS (Flipkart style) -->
  <div class="flex flex-col md:flex-row gap-4">

    <div class="flex md:flex-col gap-2 overflow-x-auto md:overflow-visible">
      <% product.images?.forEach((img,i)=>{ %>
        <img src="<%= img %>" onclick="changeImage('<%= img %>')"
        class="w-16 h-18 md:w-20 md:h-20 object-cover rounded border cursor-pointer hover:border-blue-500">
      <% }) %>
    </div>

    <div class="flex-1 relative group">
      <img id="mainImage" src="<%= product.images?.[0] || product.image %>"
      class="w-full h-[350px] md:h-[500px] object-cover rounded">

      <!-- Zoom effect -->
      <div class="hidden md:block absolute inset-0 bg-white/0 group-hover:bg-white/10 transition"></div>
    </div>

  </div>

  <!-- RIGHT: DETAILS (Meesho clean + Flipkart info) -->
  <div>

    <h1 class="text-lg md:text-2xl font-semibold"><%= product.name %></h1>

    <!-- RATING -->
    <div class="flex items-center gap-2 mt-2">
      <span class="bg-green-600 text-white px-2 py-1 text-sm rounded">
        <%= avgRating ? avgRating.toFixed(1) : 0 %> ⭐
      </span>
      <span class="text-gray-500 text-sm">(<%= reviews?.length || 0 %> Reviews)</span>
    </div>

    <!-- PRICE SECTION -->
    <div class="mt-4">
      <% if(product.discountType && product.discountType !== 'none'){ %>
        <p class="text-gray-400 line-through text-lg">₹ <%= product.price %></p>
        <p class="text-3xl font-bold text-green-600">₹ <%= product.finalPrice %></p>
        <p class="text-red-500 text-sm">
          <% if(product.discountType==='percentage'){ %>
            <%= product.discountValue %>% OFF
          <% } else { %>
            ₹ <%= product.discountValue %> OFF
          <% } %>
        </p>
      <% } else { %>
        <p class="text-3xl font-bold text-green-600">₹ <%= product.price %></p>
      <% } %>
    </div>

    <!-- BUTTONS -->
    <div class="flex gap-3 mt-5">
      <a href="/add-to-cart/<%= product._id %>"
      class="flex-1 border-2 border-orange-500 text-orange-600 py-3 text-center rounded font-semibold hover:bg-orange-50">
      🛒 Add to Cart
      </a>

      <a href="/buy-now/<%= product._id %>"
      class="flex-1 bg-orange-500 text-white py-3 text-center rounded font-semibold hover:opacity-90">
      ⚡ Buy Now
      </a>
    </div>

    <!-- DELIVERY + OFFERS -->
    <div class="mt-4 text-sm text-gray-700 space-y-1">
      <p>🚚 Free Delivery in 3-5 days</p>
      <p>💰 Cash on Delivery Available</p>
      <p>🔁 7 Days Return Policy</p>
    </div>

    <!-- HIGHLIGHTS -->
    <div class="mt-5 bg-gray-100 p-4 rounded">
      <h2 class="font-semibold mb-2">Highlights</h2>
      <ul class="text-sm text-gray-600 list-disc pl-4 space-y-1">
        <li>Premium Quality Product</li>
        <li>Best in Class Design</li>
        <li>Trusted Seller</li>
      </ul>
    </div>

    <!-- DESCRIPTION -->
    <div class="mt-5">
      <h2 class="font-semibold">Product Description</h2>
      <p class="text-gray-600 text-sm mt-2">
        <%= product.description || 'No description available' %>
      </p>
    </div>

  </div>
</div>

<!-- SIMILAR PRODUCTS -->
<div class="max-w-7xl mx-auto mt-12 px-4">
  
  <!-- Heading -->
  <div class="flex items-center justify-between mb-5">
    <h2 class="text-2xl font-bold text-gray-800">
      Similar Products 🔥
    </h2>
  </div>

  <!-- Grid -->
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-5">

    <% similarProducts.forEach(item => { %>
      
      <div class="bg-white rounded-xl shadow-sm hover:shadow-xl transition duration-300 group overflow-hidden">

        <!-- Image -->
        <div class="relative overflow-hidden">
          <a href="/product/<%= item._id %>">
            <img 
              src="<%= item.images?.[0] %>" 
              class="w-full h-44 object-cover group-hover:scale-105 transition duration-300"
            >
          </a>

          <!-- Discount badge (optional) -->
          <% if(item.discount){ %>
            <span class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded">
              <%= item.discount %>% OFF
            </span>
          <% } %>
        </div>

        <!-- Content -->
        <div class="p-3">

          <!-- Title -->
          <p class="text-sm text-gray-700 font-medium line-clamp-2 h-10">
            <%= item.name %>
          </p>

          <!-- Rating -->
          <!-- <div class="flex items-center gap-1 mt-1">
            <span class="bg-green-600 text-white text-xs px-1.5 py-0.5 rounded">
              ★ 4.3
            </span>
            <span class="text-xs text-gray-500">(120)</span>
          </div> -->

          <!-- Price -->
          <div class="mt-2 flex items-center gap-2">
            <span class="text-green-600 font-bold text-base">
              ₹ <%= item.price %>
            </span>

            <% if(item.oldPrice){ %>
              <span class="text-gray-400 text-sm line-through">
                ₹ <%= item.oldPrice %>
              </span>
            <% } %>
          </div>

        </div>

      </div>

    <% }) %>

  </div>
</div>

<!-- REVIEWS -->
<div class="max-w-5xl mx-auto mt-10 px-4">
  <h2 class="text-lg font-bold mb-3">Customer Reviews</h2>

  <% if(reviews.length>0){ %>
    <% reviews.forEach(r => { %>
      <div class="bg-white p-3 mb-2 rounded shadow">
        <p class="font-semibold"><%= r.name %></p>
        <p class="text-green-600">⭐ <%= r.rating %></p>
        <p class="text-gray-600 text-sm"><%= r.comment %></p>
      </div>
    <% }) %>
  <% } else { %>
    <p>No reviews yet</p>
  <% } %>
</div>

  <%- include("partial/footer") %>

<script>
function changeImage(src){
  document.getElementById('mainImage').src = src;
}
</script>

</body>
</html>