<!DOCTYPE html>
<html>
<head>
<title>Product Details</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔹 MAIN PRODUCT SECTION -->
<div class="max-w-7xl mx-auto p-6 grid md:grid-cols-2 gap-10 bg-white mt-10 rounded shadow">

<% if(product){ %>

<!-- LEFT SIDE -->
<div>
  <img src="<%= product.image.startsWith('http') ? product.image : '/uploads/' + product.image %>" 
class="w-full h-100 object-cover">

  <!-- BUTTONS -->
  <div class="flex gap-4 mt-6">
    <a href="/add-to-cart/<%= product._id %>" 
    class="flex-1 border border-blue-500 text-blue-500 py-3 rounded text-center font-semibold hover:bg-blue-500 hover:text-white transition">
      🛒 Add to Cart
    </a>
     
    <span class="flex-1 text-center py-3 rounded text-gray-500 font-semibold bg-green-600 text-white hover:bg-green-700 transition">
      <% if(user){ %>
  <a href="/buy-now/<%= product._id %>">⚡ Buy Now</a>
<% } else { %>
  <a href="/login">⚡ Login to Buy</a>
<% } %>
    </span>
    
  </div>
</div>

<!-- RIGHT SIDE -->
<div>

  <h1 class="text-2xl font-bold mb-3">
    <%= product.name %>
  </h1>

  <p class="text-3xl font-bold mb-2">

  <% if(product.discount > 0){ %>

    <span class="text-gray-400 line-through mr-2">
      ₹ <%= product.price %>
    </span>

    <span class="text-green-600">
      ₹ <%= product.finalPrice %>
    </span>

    <span class="text-red-500 text-lg ml-2">
      (<%= product.discount %>% OFF)
    </span>

  <% } else { %>

    <span class="text-green-600">
      ₹ <%= product.price %>
    </span>

  <% } %>

</p>

  <!-- ⭐ Rating -->
  <p class="text-yellow-500 mb-3">
    ⭐ <%= avgRating ? avgRating.toFixed(1) : "No rating" %> / 5 
    (<%= reviews ? reviews.length : 0 %> reviews)
  </p>

  <!-- DESCRIPTION -->
  <p class="text-gray-600 mb-4 leading-relaxed">
    <%= product.description %>
  </p>

  <p class="text-green-600 font-semibold mb-4">
    🚚 Free Delivery
  </p>

  <!-- PRODUCT INFO -->
  <div class="bg-gray-100 p-4 rounded">
    
    
    <p><strong>Price:</strong> ₹ <%= product.price %></p>
    <p><strong>Delivery:</strong> 4-5 Days</p>
  </div>
  <div class="max-w-7xl mx-auto mt-6 space-y-6">

  <!-- TOP FEATURES -->
  <div class="bg-gray-200 rounded-2xl p-6 flex flex-col md:flex-row items-center justify-between text-center md:text-left gap-6">

    <!-- ITEM 1 -->
    <div class="flex items-center gap-3">
      <div class="bg-white p-3 rounded-full shadow">
        <span class="text-2xl">🛍️</span>
      </div>
      <p class="font-semibold text-gray-700">Lowest Price</p>
    </div>

    <div class="hidden md:block h-10 w-px bg-gray-400"></div>

    <!-- ITEM 2 -->
    <div class="flex items-center gap-3">
      <div class="bg-white p-3 rounded-full shadow">
        <span class="text-2xl">💰</span>
      </div>
      <p class="font-semibold text-gray-700">Cash on Delivery</p>
    </div>

    <div class="hidden md:block h-10 w-px bg-gray-400"></div>

    <!-- ITEM 3 -->
    <!-- <div class="flex items-center gap-3">
      <div class="bg-white p-3 rounded-full shadow">
        <span class="text-2xl">📦</span>
      </div>
      <p class="font-semibold text-gray-700">7-day Returns</p>
    </div> -->

  </div>

  <!-- TRUST SECTION -->
  <div class="border rounded-2xl p-6 flex items-center gap-4 bg-white shadow-sm">

    <!-- ICON -->
    <div class="flex items-center gap-2 bg-purple-100 px-3 py-1 rounded-full">
      <span class="bg-purple-600 text-white w-6 h-6 flex items-center justify-center rounded-full text-sm font-bold">
        E
      </span>
      <span class="text-purple-700 font-semibold text-sm">Trusted</span>
    </div>

    <!-- TEXT -->
    <h2 class="text-gray-600 font-semibold text-lg">
      Best quality products from trusted suppliers
    </h2>

  </div>

</div>

</div>

<% } else { %>

<p class="text-center text-red-500">Product not found</p>

<% } %>

</div>






</form>


<!-- 🔥 SIMILAR PRODUCTS -->
<div class="max-w-7xl mx-auto mt-10">

<h2 class="text-2xl font-bold mb-6">Similar Products 🔥</h2>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

<% if(typeof similarProducts !== "undefined" && similarProducts.length > 0){ %>

  <% similarProducts.forEach(item => { %>

    <div class="bg-white p-4 rounded shadow hover:shadow-lg transition">

      <a href="/product/<%= item._id %>">
      <img src="<%= item.image.startsWith('http') ? item.image : '/uploads/' + item.image %>" 
      class="w-full h-40 object-cover rounded">
      </a>

      <h3 class="mt-3 font-semibold">
        <%= item.name.substring(0, 40) %>...
      </h3>

      <p class="text-green-600 font-bold">₹ <%= item.price %></p>

      <a href="/product/<%= item._id %>" 
      class="block mt-2 bg-blue-500 text-white text-center py-1 rounded hover:bg-blue-600">
        View
      </a>

    </div>

  <% }) %>

<% } else { %>

<p>No similar products found</p>

<% } %>

</div>

</div>


<!-- ⭐ REVIEWS -->
<div class="max-w-5xl mx-auto mt-10">

<h2 class="text-xl font-bold mb-4">Customer Reviews</h2>

<% if(reviews && reviews.length > 0){ %>

  <% reviews.forEach(r => { %>

    <div class="bg-white p-4 mb-3 rounded shadow">

      <h3 class="font-semibold"><%= r.name %></h3>

      <p class="text-yellow-500">
        ⭐ <%= r.rating %> / 5
      </p>

      <p class="text-gray-600"><%= r.comment %></p>

    </div>

  <% }) %>

<% } else { %>

  <p>No reviews yet 😔</p>

<% } %>

</div>


<!-- ✍️ ADD REVIEW -->
<div class="max-w-5xl mx-auto mt-10 bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Leave a Review ⭐</h2>

<form action="/add-review" method="POST">

<input type="hidden" name="productId" value="<%= product._id %>">

<input type="text" name="name" placeholder="Your Name"
class="w-full border p-2 mb-3 rounded" required>

<select name="rating" class="w-full border p-2 mb-3 rounded" required>
  <option value="">Select Rating</option>
  <option value="5">⭐⭐⭐⭐⭐ (5)</option>
  <option value="4">⭐⭐⭐⭐ (4)</option>
  <option value="3">⭐⭐⭐ (3)</option>
  <option value="2">⭐⭐ (2)</option>
  <option value="1">⭐ (1)</option>
</select>

<textarea name="comment" placeholder="Write your review..."
class="w-full border p-2 mb-3 rounded"></textarea>

<button class="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600">
Submit Review
</button>

</form>

</div>

<%- include("partial/footer") %>
<style>
.size-btn {
  padding: 10px 20px;
  border: 2px solid #ccc;
  border-radius: 999px;
  font-weight: 600;
  cursor: pointer;
  transition: 0.3s;
}

.size-btn:hover {
  border-color: #a855f7;
}

.size-btn.active {
  border-color: #a855f7;
  background-color: #f3e8ff;
  color: #a855f7;
}
</style>
<script>
const buttons = document.querySelectorAll(".size-btn");
const hiddenInput = document.getElementById("selectedSize");

if(buttons.length > 0){
  buttons.forEach(btn => {
    btn.addEventListener("click", () => {
      buttons.forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      hiddenInput.value = btn.innerText;
    });
  });
}
</script>
</body>

</html>