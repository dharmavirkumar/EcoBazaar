<%- include("partial/nav") %>

<div class="bg-white">

  <!-- HEADER -->
  <div class="bg-gray-100 border-b">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-800">
        Privacy Policy
      </h1>
      <p class="text-gray-600 mt-2 text-sm">
        Last Updated: March 2026
      </p>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="max-w-5xl mx-auto px-4 py-8 space-y-8 text-gray-700 leading-relaxed">

    <!-- INTRO -->
    <section>
      <p>
        Welcome to <strong>LioKart</strong>. Your privacy is important to us. 
        This Privacy Policy explains how we collect, use, and protect your information.
      </p>
    </section>

    <!-- INFO WE COLLECT -->
    <section>
      <h2 class="text-xl font-semibold mb-2">1. Information We Collect</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li>Name, email address, phone number</li>
        <li>Shipping & billing address</li>
        <li>Payment details (secured via payment gateways)</li>
        <li>Browsing behavior & search history</li>
      </ul>
    </section>

    <!-- HOW WE USE -->
    <section>
      <h2 class="text-xl font-semibold mb-2">2. How We Use Your Information</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li>To process orders and payments</li>
        <li>To improve user experience</li>
        <li>To send order updates and notifications</li>
        <li>To provide customer support</li>
      </ul>
    </section>

    <!-- DATA PROTECTION -->
    <section>
      <h2 class="text-xl font-semibold mb-2">3. Data Protection</h2>
      <p>
        We use secure servers and encryption to protect your personal data. 
        Your payment information is processed through trusted third-party gateways.
      </p>
    </section>

    <!-- COOKIES -->
    <section>
      <h2 class="text-xl font-semibold mb-2">4. Cookies</h2>
      <p>
        We use cookies to enhance your browsing experience, remember preferences, 
        and analyze site traffic.
      </p>
    </section>

    <!-- SHARING -->
    <section>
      <h2 class="text-xl font-semibold mb-2">5. Information Sharing</h2>
      <p>
        We do not sell your personal data. Information may be shared only with:
      </p>
      <ul class="list-disc pl-6 space-y-1 mt-2">
        <li>Delivery partners</li>
        <li>Payment gateways</li>
        <li>Legal authorities (if required)</li>
      </ul>
    </section>

    <!-- USER RIGHTS -->
    <section>
      <h2 class="text-xl font-semibold mb-2">6. Your Rights</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li>Access your personal data</li>
        <li>Request correction or deletion</li>
        <li>Opt-out of marketing emails</li>
      </ul>
    </section>

    <!-- THIRD PARTY -->
    <section>
      <h2 class="text-xl font-semibold mb-2">7. Third-Party Services</h2>
      <p>
        We may use third-party tools like analytics and payment services. 
        These providers have their own privacy policies.
      </p>
    </section>

    <!-- CHANGES -->
    <section>
      <h2 class="text-xl font-semibold mb-2">8. Policy Updates</h2>
      <p>
        We may update this Privacy Policy from time to time. Changes will be posted on this page.
      </p>
