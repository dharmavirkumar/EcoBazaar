<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width, initial-scale=1.0">
    <title>my Orders</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <%- include("partial/nav") %>
    <% if(orders.length > 0){ %>

  <div class="space-y-6">

  <% orders.forEach(order => { %>

    <div class="bg-white rounded-xl shadow-md hover:shadow-lg transition p-5 flex flex-col md:flex-row gap-5">

      <!-- IMAGE -->
      <div class="w-full md:w-32 flex-shrink-0">
        <img 
          src="<%= order.productId?.image || '/default.png' %>" 
          class="w-full h-32 object-cover rounded-lg border">
      </div>

      <!-- DETAILS -->
      <div class="flex-1">

        <h2 class="text-lg font-semibold text-gray-800">
          <%= order.productId?.name %>
        </h2>

        <p class="text-gray-600 mt-1">
          ₹ <%= order.productId?.price %>
        </p>

        <% if(order.size){ %>
          <p class="text-sm text-gray-500 mt-1">
            Size: <span class="font-medium"><%= order.size %></span>
          </p>
        <% } %>

        <p class="text-sm text-gray-400 mt-2">
          Ordered on: <%= new Date(order.createdAt).toDateString() %>
        </p>

      </div>

      <!-- STATUS + ACTION -->
      <div class="flex flex-col justify-between items-end">

        <!-- STATUS BADGE -->
        <span class="px-3 py-1 text-sm rounded-full font-medium
          <%= order.status === 'Pending' ? 'bg-yellow-100 text-yellow-700' : 
              order.status === 'Delivered' ? 'bg-green-100 text-green-700' : 
              order.status === 'Cancelled' ? 'bg-red-100 text-red-600' :
              'bg-blue-100 text-blue-600' %>">
          <%= order.status %>
        </span>
   
        <!-- BUTTON -->
        <div class="mt-4">

          <% if(order.status !== "Cancelled" && order.status !== "Delivered") { %>

            <a href="/cancel-order/<%= order._id %>"
              class="bg-red-500 hover:bg-red-600 text-white px-4 py-1.5 rounded-md text-sm transition">
              Cancel ❌
            </a>

          <% } else { %>

            <span class="text-gray-400 text-sm">
              Not Allowed
            </span>

          <% } %>
                  

        </div> <a href="/download-invoice/<%= order._id %>"
   class="bg-green-500 text-white px-3 py-1 rounded">
   Download Invoice 🧾
</a>

      </div>

    </div>

  <% }) %>

  </div>

<% } else { %>

  <!-- EMPTY STATE -->
  <div class="text-center mt-20">
    <h2 class="text-xl font-semibold text-gray-700">No orders yet 😔</h2>
    <p class="text-gray-500 mt-2">Start shopping and place your first order!</p>

    <a href="/" 
      class="inline-block mt-4 bg-yellow-400 hover:bg-yellow-500 px-5 py-2 rounded font-medium">
      Shop Now 🛍️
    </a>
  </div>

<% } %>



<%- include("partial/footer") %>
</body>
</html>