<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Orders</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-6xl mx-auto px-4 py-6">

<h1 class="text-2xl font-bold mb-6">My Orders</h1>

<% if(orders.length > 0){ %>

<div class="space-y-6">

<% orders.forEach(order => { %>

<div class="bg-white rounded-xl shadow-sm hover:shadow-lg transition p-5 border">

  <!-- HEADER -->
  <div class="flex flex-col md:flex-row justify-between gap-4 border-b pb-4">

    <div>
      <p class="text-xs text-gray-500">ORDER ID</p>
      <p class="font-semibold text-gray-800"><%= order._id %></p>
    </div>

    <div>
      <p class="text-xs text-gray-500">DATE</p>
      <p class="font-medium"><%= new Date(order.createdAt).toDateString() %></p>
    </div>

    <div>
      <p class="text-xs text-gray-500">TOTAL</p>
      <p class="font-bold text-lg text-gray-900">₹ <%= order.totalAmount %></p>
    </div>

  </div>

  <!-- ITEMS -->
  <div class="mt-4 space-y-4">

  <% order.items.forEach(item => { %>

  <div class="flex gap-4 border rounded-lg p-3 hover:bg-gray-50 transition">

   <img 
  src="<%= item.image ? item.image : '/default.png' %>" 
  onerror="this.src='/default.png'"
  class="w-24 h-24 object-cover rounded border"
/>

    <div class="flex-1">

      <h2 class="font-semibold text-gray-800">
        <%= item.name %>
      </h2>

      <p class="text-sm text-gray-600 mt-1">
        ₹ <%= item.price %> × <%= item.quantity %>
      </p>

      <% if(item.size){ %>
      <span class="inline-block mt-1 text-xs bg-gray-200 px-2 py-0.5 rounded">
        Size: <%= item.size %>
      </span>
      <% } %>

    </div>

  </div>

  <% }) %>

  </div>
<a href="/track-order/<%= order._id %>" class="btn">
  Track Order
</a>
  <!-- STATUS + ACTION -->
  <div class="flex flex-col md:flex-row justify-between items-center mt-5 gap-4">

    <!-- STATUS BADGE -->
    <span class="px-4 py-1 rounded-full text-sm font-semibold
      <%= order.status === 'Placed' ? 'bg-yellow-100 text-yellow-700' : 
          order.status === 'Shipped' ? 'bg-blue-100 text-blue-700' :
          order.status === 'Out for Delivery' ? 'bg-purple-100 text-purple-700' :
          order.status === 'Delivered' ? 'bg-green-100 text-green-700' : 
          'bg-red-100 text-red-600' %>">
      <%= order.status %>
    </span>

    <!-- BUTTONS -->
    <div class="flex gap-3">

      <% if(order.status !== "Cancelled" && order.status !== "Delivered") { %>
      <a href="/cancel-order/<%= order._id %>"
        class="px-4 py-1.5 bg-red-500 hover:bg-red-600 text-white text-sm rounded">
        Cancel
      </a>
      <% } %>

      <a href="/download-invoice/<%= order._id %>"
        class="px-4 py-1.5 bg-green-500 hover:bg-green-600 text-white text-sm rounded">
        Invoice
      </a>

    </div>

  </div>

  <!-- PAYMENT -->
  <div class="mt-3 text-sm">
    Payment:
    <span class="font-medium">
      <%= order.paymentMethod %> 
      <span class="text-gray-500">(<%= order.paymentStatus %>)</span>
    </span>
  </div>

  <!-- ADDRESS -->
  <div class="mt-4 text-sm bg-gray-50 p-3 rounded border">

    <p class="font-semibold mb-1">Delivery Address</p>

    <p>
      <%= order.address?.house %>, <%= order.address?.area %>, 
      <%= order.address?.city %>, <%= order.address?.state %> - <%= order.address?.pincode %>
    </p>

    <% if(order.address?.landmark){ %>
    <p class="text-gray-500">Landmark: <%= order.address.landmark %></p>
    <% } %>

  </div>

  <!-- TRACKING -->

  <div class="mt-5">

    <p class="text-sm font-semibold mb-3">Order Status</p>

    <% const steps = ["Placed", "Shipped", "Out for Delivery", "Delivered"]; %>

    <div class="flex justify-between items-center">

    <% steps.forEach((step, i) => { %>

      <div class="flex-1 text-center relative">

        <!-- LINE -->
        <% if(i !== steps.length - 1){ %>
        <div class="absolute top-3 left-1/2 w-full h-1
          <%= steps.indexOf(order.status) > i ? 'bg-green-500' : 'bg-gray-300' %>">
        </div>
        <% } %>

        <!-- DOT -->
        <div class="w-6 h-6 mx-auto rounded-full flex items-center justify-center text-xs
          <%= steps.indexOf(order.status) >= i 
              ? 'bg-green-500 text-white' 
              : 'bg-gray-300' %>">
          ✓
        </div>

        <p class="text-xs mt-1"><%= step %></p>

      </div>

    <% }) %>

    </div>

  </div>

</div>

<% }) %>

</div>

<% } else { %>

<!-- EMPTY STATE -->
<div class="text-center mt-20">

  <img src="/empty.png" class="w-40 mx-auto mb-4 opacity-80">

  <h2 class="text-xl font-semibold text-gray-700">No orders yet 😔</h2>

  <p class="text-gray-500 mt-2">Looks like you haven't placed any order</p>

  <a href="/" 
    class="inline-block mt-5 bg-yellow-400 hover:bg-yellow-500 px-6 py-2 rounded font-medium shadow">
    Shop Now 🛍️
  </a>

</div>

<% } %>

</div>

<%- include("partial/footer") %>

</body>
</html>