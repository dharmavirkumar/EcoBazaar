<!-- 🔥 MAIN -->
<div class="max-w-7xl mx-auto px-4 mt-6 flex gap-6">

  <!-- 🧠 SIDEBAR -->
  <div class="bg-white p-5 rounded-xl shadow w-64 h-fit sticky top-24">

    <h2 class="font-bold text-lg mb-4">Filters</h2>

    <!-- CATEGORY -->
    <div class="mb-6">
      <h3 class="font-semibold mb-2">Category</h3>

      <ul class="space-y-2 text-sm">

        <li>
          <a href="/category/<%= main %>/All"
             class="block px-2 py-1 rounded 
             <%= sub === 'All' ? 'bg-blue-100 text-blue-600 font-semibold' : 'hover:bg-gray-100' %>">
            All
          </a>
        </li>

        <% subCategories.forEach(cat => { %>
          <li>
            <a href="/category/<%= main %>/<%= cat %>"
               class="block px-2 py-1 rounded 
               <%= sub === cat ? 'bg-blue-100 text-blue-600 font-semibold' : 'hover:bg-gray-100' %>">
              <%= cat %>
            </a>
          </li>
        <% }) %>

      </ul>
    </div>

    <!-- PRICE -->
    <div>
      <h3 class="font-semibold mb-2">Price</h3>
      <ul class="space-y-2 text-sm">
        <li><a href="?price=0-500" class="block hover:text-blue-500">Under ₹500</a></li>
        <li><a href="?price=500-1000" class="block hover:text-blue-500">₹500 - ₹1000</a></li>
        <li><a href="?price=1000-2000" class="block hover:text-blue-500">₹1000 - ₹2000</a></li>
      </ul>
    </div>

  </div>

  <!-- 🛍 PRODUCTS -->
  <div class="flex-1">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-4">
      <h1 class="text-xl font-bold capitalize">
        <%= main %> / <%= sub %> (<%= products.length %>)
      </h1>

      <!-- SORT -->
      <select class="border px-2 py-1 rounded text-sm">
        <option>Sort By</option>
        <option>Price Low → High</option>
        <option>Price High → Low</option>
      </select>
    </div>

    <% if(products.length === 0){ %>

      <div class="text-center py-20">
        <p class="text-gray-500 text-xl">No products found 😔</p>
      </div>

    <% } else { %>

    <!-- GRID -->
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

      <% products.forEach(product => { %>

        <div class="bg-white rounded-xl shadow hover:shadow-xl transition group overflow-hidden">

          <!-- IMAGE -->
          <div class="relative">
            <a href="/product/<%= product._id %>">
              <img 
                src="<%= product.images?.[0] || '/default.png' %>"
                class="w-full h-44 object-contain p-3 group-hover:scale-105 transition">
            </a>

            <!-- DISCOUNT -->
            <% if(product.discountValue){ %>
              <span class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded">
                <%= product.discountType === 'percentage' ? product.discountValue + '%' : '₹' + product.discountValue %> OFF
              </span>
            <% } %>
          </div>

          <!-- DETAILS -->
          <div class="p-3">

            <h2 class="text-sm font-semibold line-clamp-2 h-10">
              <%= product.name %>
            </h2>

            <!-- PRICE -->
            <div class="mt-1 flex items-center gap-2">
              <% if(product.discountValue){ %>

                <span class="text-green-600 font-bold text-lg">
                  ₹<%= product.finalPrice %>
                </span>

                <span class="line-through text-gray-400 text-sm">
                  ₹<%= product.price %>
                </span>

              <% } else { %>

                <span class="text-green-600 font-bold text-lg">
                  ₹<%= product.price %>
                </span>

              <% } %>
            </div>

            <!-- RATING -->
            <p class="text-yellow-500 text-xs mt-1">
              ⭐ 
              <%= product.avgRating != null 
                  ? product.avgRating.toFixed(1) 
                  : "No rating" %>
            </p>

            <!-- BUTTONS -->
            <div class="flex gap-2 mt-3">

              <a href="/product/<%= product._id %>" 
                 class="flex-1 text-center bg-blue-500 text-white py-1.5 rounded hover:bg-blue-600 text-sm">
                View
              </a>

              <a href="/add-to-cart/<%= product._id %>" 
                 class="flex-1 text-center bg-yellow-400 py-1.5 rounded hover:bg-yellow-500 text-sm">
                Cart
              </a>

            </div>

          </div>

        </div>

      <% }) %>

    </div>

    <% } %>

  </div>

</div>

<%- include("partial/footer") %>

</body>
</html>