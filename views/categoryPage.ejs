    <div>
      <h1 class="text-3xl font-bold">Big Sale 🎉</h1>
      <p class="text-sm mt-1">Up to 70% OFF on <%= main %></p>
    </div>

    <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" class="w-24">
  </div>
</div>

