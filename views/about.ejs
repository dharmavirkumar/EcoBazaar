<!DOCTYPE html>
<html>
<head>
<title>About Us</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔥 HERO SECTION -->
<div class="bg-gradient-to-r from-blue-600 to-purple-600 text-white py-16 text-center">
  <h1 class="text-4xl font-bold">About Us</h1>
  <p class="mt-4 text-lg">Know more about our journey & mission</p>
</div>

<!-- 🧱 ABOUT CONTENT -->
<div class="max-w-6xl mx-auto p-6">

<!-- About -->
<div class="bg-white p-6 rounded shadow mb-6">
  <h2 class="text-2xl font-bold mb-3">Who We Are</h2>
  <p class="text-gray-600 leading-relaxed">
    Welcome to <span class="font-semibold text-blue-600">MyShop</span> — your one-stop destination for shopping 
