<div class="grid md:grid-cols-2 gap-6 mb-6">

  <div class="bg-white p-6 rounded shadow">
    <h2 class="text-xl font-bold mb-3">🎯 Our Mission</h2>
    <p class="text-gray-600">
      To provide high-quality products with fast delivery and excellent customer service, 
      making online shopping simple and reliable for everyone.
    </p>
  </div>

  <div class="bg-white p-6 rounded shadow">
    <h2 class="text-xl font-bold mb-3">🚀 Our Vision</h2>
    <p class="text-gray-600">
      To become one of the most trusted and customer-friendly eCommerce platforms 
      by continuously improving user experience and product quality.
    </p>
  </div>

</div>

<!-- Why Choose Us -->
<div class="bg-white p-6 rounded shadow mb-6">
