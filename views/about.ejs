  <div class="grid md:grid-cols-3 gap-6 text-center">

    <div>
      <h3 class="text-lg font-semibold">⚡ Fast Delivery</h3>
      <p class="text-gray-600">Quick and reliable shipping across all locations.</p>
    </div>

    <div>
      <h3 class="text-lg font-semibold">💰 Best Prices</h3>
      <p class="text-gray-600">Affordable pricing with exciting offers.</p>
    </div>

    <div>
      <h3 class="text-lg font-semibold">🔒 Secure Payment</h3>
      <p class="text-gray-600">100% safe and secure payment methods.</p>
    </div>

  </div>
</div>

<!-- Contact -->
<div class="bg-white p-6 rounded shadow text-center">
  <h2 class="text-xl font-bold mb-2">📞 Contact Us</h2>
  <p class="text-gray-600">Email: support@myshop.com</p>
  <p class="text-gray-600">Phone: +91 ************</p>
</div>

</div>

