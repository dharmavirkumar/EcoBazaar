<!DOCTYPE html>
<html>
<head>
  <title>Edit Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<div class="max-w-6xl mx-auto mt-10 bg-white p-8 rounded-2xl shadow-lg">

  <h1 class="text-3xl font-bold mb-6">✏️ Edit Product</h1>

  <form action="/admin/edit-product/<%= product._id %>" method="POST" enctype="multipart/form-data">

    <div class="grid md:grid-cols-2 gap-6">

      <!-- LEFT -->
      <div>

        <input type="text" name="name" value="<%= product.name %>"
          class="w-full border p-3 mb-3 rounded" placeholder="Product Name">

        <input type="number" name="price" value="<%= product.price %>"
          class="w-full border p-3 mb-3 rounded" placeholder="Price">

        <textarea name="description"
          class="w-full border p-3 mb-3 rounded"
          placeholder="Description"><%= product.description %></textarea>

        <!-- CATEGORY -->
        <select name="category" class="w-full border p-3 mb-3 rounded">
          <option <%= product.category=="fashion"?"selected":"" %>>fashion</option>
          <option <%= product.category=="electronics"?"selected":"" %>>electronics</option>
          <option <%= product.category=="beauty"?"selected":"" %>>beauty</option>
          <option <%= product.category=="jewellery"?"selected":"" %>>jewellery</option>
        </select>

        <!-- HIGHLIGHTS -->
        <div>
          <label class="font-medium">Highlights</label>

          <div id="highlightContainer">
            <% if(product.highlights){ %>
              <% product.highlights.forEach(h => { %>
                <input name="highlights[]" value="<%= h %>"
                  class="w-full border p-2 mt-2 rounded">
              <% }) %>
            <% } %>
          </div>

          <button type="button" onclick="addHighlight()" class="text-blue-600 mt-2">
            + Add Highlight
          </button>
        </div>

        <!-- SPECIFICATIONS -->
        <div class="mt-4">
          <label class="font-medium">Specifications</label>

          <div id="specContainer">
            <% if(product.specifications){ %>
              <% Object.keys(product.specifications).forEach(key => { %>
                <div class="flex gap-2 mt-2">
                  <input name="specKey[]" value="<%= key %>" class="w-1/2 border p-2 rounded">
                  <input name="specValue[]" value="<%= product.specifications[key] %>" class="w-1/2 border p-2 rounded">
                </div>
              <% }) %>
            <% } %>
          </div>

          <button type="button" onclick="addSpec()" class="text-blue-600 mt-2">
            + Add Spec
          </button>
        </div>

      </div>

      <!-- RIGHT -->
      <div>

        <!-- EXISTING IMAGES -->
        <h3 class="font-semibold mb-2">Current Images</h3>

        <div class="flex gap-3 flex-wrap mb-4">
          <% if(product.images){ %>
            <% product.images.forEach(img => { %>

              <div class="relative group">
                <img src="<%= img %>" class="w-24 h-24 object-cover rounded border">

                <!-- DELETE BUTTON -->
                <button type="button"
                  onclick="removeImage(this)"
                  class="absolute top-1 right-1 bg-red-600 text-white text-xs px-2 rounded hidden group-hover:block">
                  ✕
                </button>

                <input type="hidden" name="existingImages" value="<%= img %>">

              </div>

            <% }) %>
          <% } %>
        </div>

        <!-- DRAG DROP -->
        <div id="dropArea"
          class="border-2 border-dashed border-gray-400 p-6 text-center rounded cursor-pointer hover:bg-gray-50">

          <p>📂 Drag & Drop New Images OR Click</p>
          <input type="file" id="imageInput" name="images" multiple class="hidden">
        </div>

        <!-- PREVIEW -->
        <div id="previewContainer" class="flex gap-3 flex-wrap mt-4"></div>

        <button class="w-full bg-blue-600 text-white py-3 mt-6 rounded-xl">
          🚀 Update Product
        </button>

      </div>

    </div>

  </form>
</div>

<!-- JS -->
<script>
const dropArea = document.getElementById("dropArea");
const input = document.getElementById("imageInput");
const previewContainer = document.getElementById("previewContainer");

// ✅ STORE ALL FILES HERE
let allFiles = [];

// CLICK
dropArea.addEventListener("click", () => input.click());

// DRAG OVER
dropArea.addEventListener("dragover", e => {
  e.preventDefault();
  dropArea.classList.add("bg-blue-100");
});

// DRAG LEAVE
dropArea.addEventListener("dragleave", () => {
  dropArea.classList.remove("bg-blue-100");
});

// DROP
dropArea.addEventListener("drop", e => {
  e.preventDefault();
  dropArea.classList.remove("bg-blue-100");

  addFiles(e.dataTransfer.files);
});

// SELECT
input.addEventListener("change", () => {
  addFiles(input.files);
});

// ✅ ADD FILES FUNCTION
function addFiles(files) {
  const newFiles = Array.from(files);

  // append instead of replace
  allFiles = allFiles.concat(newFiles);

  updateInputFiles();
  previewImages();
}

// ✅ UPDATE INPUT FILES (IMPORTANT)
function updateInputFiles() {
  const dataTransfer = new DataTransfer();

  allFiles.forEach(file => dataTransfer.items.add(file));

  input.files = dataTransfer.files;
}

// ✅ PREVIEW
function previewImages() {
  previewContainer.innerHTML = "";

  allFiles.forEach((file, index) => {
    const div = document.createElement("div");
    div.className = "relative";

    const img = document.createElement("img");
    img.src = URL.createObjectURL(file);
    img.className = "w-24 h-24 object-cover rounded border";

    // ❌ remove button
    const btn = document.createElement("button");
    btn.innerText = "✕";
    btn.className = "absolute top-1 right-1 bg-red-600 text-white text-xs px-2 rounded";

    btn.onclick = () => {
      allFiles.splice(index, 1);
      updateInputFiles();
      previewImages();
    };

    div.appendChild(img);
    div.appendChild(btn);
    previewContainer.appendChild(div);
  });
}
</script>

</body>
</html>