<div class="max-w-3xl mx-auto mt-10 bg-white p-6 rounded shadow">

<h1 class="text-2xl font-bold mb-4">✏️ Edit Product</h1>

<form action="/admin/edit-product/<%= product._id %>" method="POST" enctype="multipart/form-data">

<input type="text" name="name" value="<%= product.name %>" class="w-full border p-2 mb-3">

<input type="number" name="price" value="<%= product.price %>" class="w-full border p-2 mb-3">

<select name="category" class="w-full border p-2 mb-3">
  <option <%= product.category=="electronics"?"selected":"" %>>electronics</option>
  <option <%= product.category=="fashion"?"selected":"" %>>fashion</option>
</select>

<img src="<%= product.image %>" class="w-32 mb-3">

<input type="file" name="image" class="mb-3">

<textarea name="description" class="w-full border p-2 mb-3">
<%= product.description %>
</textarea>

<button class="bg-blue-500 text-white px-4 py-2 rounded">
Update
</button>

</form>
</div>