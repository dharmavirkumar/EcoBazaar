<!DOCTYPE html>
<html>
<head>
  <title>LioKart Premium Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 flex">

<!-- SIDEBAR -->
<div class="w-64 bg-gradient-to-b from-gray-900 to-gray-800 text-white min-h-screen p-5">

  <h1 class="text-2xl font-bold mb-6">⚡ LioKart Admin</h1>

  <button onclick="showTab('dashboard')" class="block w-full text-left py-2 hover:bg-gray-700 rounded">📊 Dashboard</button>
  <button onclick="showTab('products')" class="block w-full text-left py-2 hover:bg-gray-700 rounded">📦 Products</button>
  <button onclick="showTab('orders')" class="block w-full text-left py-2 hover:bg-gray-700 rounded">🧾 Orders</button>

  <a href="/logout" class="block bg-red-500 text-center py-2 rounded mt-6">Logout</a>
</div>

<!-- MAIN -->
<div class="flex-1 p-6">

<!-- HEADER -->
<div class="flex justify-between mb-6">
  <h2 class="text-2xl font-bold">Admin Panel</h2>
  <a href="/" class="bg-yellow-400 px-4 py-2 rounded">Back</a>
</div>

<!-- ================= DASHBOARD ================= -->
<div id="dashboard" class="tab-content">

<div class="grid md:grid-cols-3 gap-6">

  <div class="bg-white p-6 rounded shadow text-center">
    <p>Total Products</p>
    <h2 class="text-3xl text-blue-500"><%= totalProducts %></h2>
  </div>

  <div class="bg-white p-6 rounded shadow text-center">
    <p>Total Orders</p>
    <h2 class="text-3xl text-green-500"><%= totalOrders %></h2>
  </div>

  <div class="bg-white p-6 rounded shadow text-center">
    <p>Revenue</p>
    <h2 class="text-3xl text-purple-500">₹ <%= revenue %></h2>
  </div>

</div>
</div>

<!-- ================= PRODUCTS ================= -->
<div id="products" class="tab-content hidden">

<!-- ADD PRODUCT -->
<div class="bg-white p-6 rounded shadow mb-6">

<h2 class="text-xl mb-4">➕ Add Product</h2>

<form action="/add-product" method="POST" enctype="multipart/form-data"
 class="grid md:grid-cols-2 gap-4">

<input name="name" placeholder="Name" required class="border p-2">
<input name="price" type="number" placeholder="Price" required class="border p-2">

<textarea name="description" placeholder="Description" class="border p-2 col-span-2"></textarea>

<input name="category" placeholder="Category" class="border p-2">
<input name="mainCategory" placeholder="Main Category" class="border p-2">

<input name="subCategory" placeholder="Sub Category" class="border p-2">

<select name="discountType" class="border p-2">
  <option value="none">No Discount</option>
  <option value="percentage">%</option>
  <option value="flat">₹ Flat</option>
</select>

<input name="discountValue" type="number" placeholder="Discount Value" class="border p-2">

<input type="file" name="images" multiple class="border p-2 col-span-2">

<button class="bg-blue-500 text-white py-2 col-span-2">Add Product</button>

</form>
</div>

<!-- PRODUCT LIST -->
<div class="grid md:grid-cols-3 gap-4">

<% products.forEach(p => { %>

<div class="bg-white p-4 rounded shadow">

<img src="<%= p.images?.[0] || '/default.png' %>"
 class="w-full h-40 object-cover">

<h3 class="mt-2 font-bold"><%= p.name %></h3>

<p class="text-gray-400 line-through">₹ <%= p.price %></p>
<p class="text-green-600 font-bold">₹ <%= p.finalPrice || p.price %></p>

<p class="text-xs text-gray-500">
<%= p.mainCategory %> / <%= p.subCategory %>
</p>

<!-- SIZES -->
<% if(p.sizes && p.sizes.length > 0){ %>
<div class="mt-2 text-xs">
Sizes:
<% p.sizes.forEach(s => { %>
<span class="bg-gray-200 px-2 py-1 rounded">
<%= s.size %>
</span>
<% }) %>
</div>
<% } %>

<div class="flex gap-2 mt-3">

<a href="/admin/edit-product/<%= p._id %>"
 class="bg-yellow-400 flex-1 text-center py-1 rounded">Edit</a>

<a href="/admin/delete-product/<%= p._id %>"
 class="bg-red-500 text-white flex-1 text-center py-1 rounded">Delete</a>

</div>

</div>

<% }) %>

</div>

</div>

<!-- ================= ORDERS ================= -->
<div id="orders" class="tab-content hidden">

<div class="space-y-4">

<% orders.forEach(o => { %>

<div class="bg-white p-4 rounded shadow">

<div class="flex justify-between border-b pb-2">

<div>
<p class="font-bold">Order: <%= o._id %></p>
<p class="text-xs"><%= new Date(o.createdAt).toDateString() %></p>
</div>

<div class="text-right text-sm">
<p>💳 <%= o.paymentMethod %></p>
<p class="text-green-600"><%= o.paymentStatus %></p>
</div>

</div>

<!-- ITEMS -->
<div class="mt-2">
<% o.items.forEach(i => { %>

<div class="flex justify-between text-sm">
<span><%= i.name %> (x<%= i.quantity %>)</span>
<span>₹ <%= i.price * i.quantity %></span>
</div>

<% }) %>
</div>

<!-- STATUS -->
<form action="/admin/update-status/<%= o._id %>" method="POST" class="mt-2 flex gap-2">

<select name="status" class="border p-1">
<option <%= o.status==='Placed'?'selected':'' %>>Placed</option>
<option <%= o.status==='Shipped'?'selected':'' %>>Shipped</option>
<option <%= o.status==='Out for Delivery'?'selected':'' %>>Out for Delivery</option>
<option <%= o.status==='Delivered'?'selected':'' %>>Delivered</option>
<option <%= o.status==='Cancelled'?'selected':'' %>>Cancelled</option>
</select>

<button class="bg-blue-500 text-white px-2">Update</button>

</form>

</div>

<% }) %>

</div>

</div>

</div>

<script>
function showTab(tab){
document.querySelectorAll(".tab-content").forEach(el=>el.classList.add("hidden"));
document.getElementById(tab).classList.remove("hidden");
}
</script>

</body>
</html>