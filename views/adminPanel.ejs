<!DOCTYPE html>
<html>
<head>
  <title>Admin Panel</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<!-- HEADER -->
<div class="bg-gray-900 text-white p-4 flex justify-between">
  <h1 class="text-xl font-bold">Admin Panel</h1>
  <a href="/" class="bg-yellow-400 text-black px-3 py-1 rounded">Back</a>
</div>

<div class="max-w-7xl mx-auto mt-6">

  <!-- TABS -->
  <div class="flex gap-4 border-b pb-2">
    <button onclick="showTab('dashboard')" class="tab-btn text-blue-500 font-semibold">Dashboard</button>
    <button onclick="showTab('products')" class="tab-btn">Products</button>
    <button onclick="showTab('orders')" class="tab-btn">Orders</button>
  </div>

  <!-- DASHBOARD -->
  <div id="dashboard" class="tab-content mt-6">
    <div class="grid md:grid-cols-3 gap-6">
      <div class="bg-white p-6 rounded shadow text-center">
        <h2>Total Products</h2>
        <p class="text-3xl text-blue-500"><%= totalProducts %></p>
      </div>
      <div class="bg-white p-6 rounded shadow text-center">
        <h2>Total Orders</h2>
        <p class="text-3xl text-green-500"><%= totalOrders %></p>
      </div>
      <div class="bg-white p-6 rounded shadow text-center">
        <h2>Revenue</h2>
        <p class="text-3xl text-purple-500">₹ <%= revenue %></p>
      </div>
    </div>
  </div>

  <!-- PRODUCTS -->
  <div id="products" class="tab-content hidden mt-6">

    <!-- ADD PRODUCT -->
    <form action="/add-product" method="POST" enctype="multipart/form-data"
      class="bg-white p-6 rounded shadow mb-6">

      <h2 class="text-xl font-bold mb-4">Add Product</h2>

      <input type="text" name="name" placeholder="Product Name"
        class="w-full border p-2 mb-3 rounded" required>

      <input type="number" name="price" placeholder="Price"
        class="w-full border p-2 mb-3 rounded" required>

      <textarea name="description" placeholder="Description"
        class="w-full border p-2 mb-3 rounded"></textarea>

      <select name="category" class="w-full border p-2 mb-3 rounded">
        <option value="fashion">Fashion</option>
        <option value="electronics">Electronics</option>
        <option value="Beauty">Beauty</option>
        <option value="Jewellery">Accessories</option>
      </select>


      <select name="mainCategory" class="w-full border p-2 mb-3 rounded">
  <option value="">Select Main Category</option>
  
  <option>Footwear</option>
  <option>Accessories</option>
  <option>Beauty</option>
  <option>Electronics</option>
  <option>Fashion</option>
  
</select>

<select name="subCategory" class="w-full border p-2 mb-3 rounded">
  <option value="">Select Sub Category</option>

  <!-- Top Wear -->
  <option>Shirts</option>
  <option>T-Shirts</option>

  <option>Sports Shoes</option>
  <option>Casual Shoes</option>
  <option>Formal Shoes</option>

  <!-- Bottom Wear -->
  <option>Jeans</option>
  <option>Trousers</option>

  <option>Kurtas</option>
  <option>Kurta Sets</option>

  <!-- Accessories -->
  <option>Watches</option>
  <option>Wallets</option>
  <option>Jewellery</option>
  <option>Sunglasses</option>
  <option>Belts</option>

  <option>Hair Oil</option>
  <option>Shampoo</option>
  <option>Conditioner</option>
  <option>Trimmers</option>
  <option>Hair Wax</option>
  <option>Hair Spray</option>
  <option>Face Wash</option>
  <option>Body Lotion</option>
  <option>Face Cream</option>
  <option>Grooming Kit</option>
  <option>Beard Kit</option>


   <!-- ✅ ELECTRONICS -->
  <option>Neckband</option>
  <option>Speakers</option>
  <option>Cases & Covers</option>
  <option>Bluetooth Earbuds</option>
  <option>Wired Earphone</option>

  <option>Mobile Holders</option>
  <option>Chargers & Cables</option>
  <option>Power Banks</option>
  <option>Microphone</option>
  <option>Selfie Stick & Ringlight</option>
  <option>MixerGrinder</option>
  <option>Dinnerware Sets</option>
 


</select>



      <!-- 🔥 DRAG DROP -->
      <div id="dropArea" 
        class="border-2 border-dashed border-gray-400 p-6 text-center rounded cursor-pointer hover:bg-gray-50">

        <p>📂 Drag & Drop Images OR Click</p>
        <input type="file" id="imageInput" name="images" multiple class="hidden">
      </div>

      <div id="previewContainer" class="flex gap-3 flex-wrap mt-4"></div>

      <!-- DISCOUNT -->
      <select name="discountType" class="w-full border p-2 mb-3 rounded">
        <option value="none">No Discount</option>
        <option value="percentage">Percentage (%)</option>
        <option value="flat">Flat ₹</option>
      </select>

      <input type="number" name="discountValue" placeholder="Discount Value"
      class="w-full border p-2 mb-3 rounded">

      <button class="bg-blue-500 text-white px-4 py-2 rounded">
        Add Product
      </button>
    </form>

    <!-- PRODUCT LIST -->
    <div class="grid md:grid-cols-3 lg:grid-cols-4 gap-6">

      <% products.forEach(p => { %>

      <div class="bg-white p-4 rounded shadow">

        <img 
        src="<%= p.images && p.images.length > 0 
                ? p.images[0] 
                : '/uploads/' + p.image %>" 
        class="w-full h-40 object-cover rounded">

        <h3 class="mt-2 font-semibold"><%= p.name %></h3>
        <p class="text-green-600">₹ <%= p.price %></p>

        <div class="flex gap-2 mt-3">
          <a href="/admin/edit-product/<%= p._id %>"
            class="flex-1 bg-yellow-400 text-center py-1 rounded">Edit</a>

          <a href="/admin/delete-product/<%= p._id %>"
            class="flex-1 bg-red-500 text-white text-center py-1 rounded">
            Delete
          </a>
        </div>

      </div>

      <% }) %>

    </div>

  </div>

  <!-- ORDERS -->
  <div id="orders" class="tab-content hidden mt-6">

    <div class="bg-white p-6 rounded shadow">

      <h2 class="text-xl font-bold mb-4">All Orders</h2>

      <% orders.forEach(o => { %>

      <div class="border-b py-4 flex justify-between">

        <div>
          <p class="font-semibold"><%= o.productId?.name %></p>
          <p>₹ <%= o.productId?.price %></p>
          <p class="text-sm text-gray-500"><%= o.address %></p>
        </div>

        <form action="/admin/update-status/<%= o._id %>" method="POST">
          <select name="status" class="border p-1">
            <option <%= o.status==='Pending'?'selected':'' %>>Pending</option>
            <option <%= o.status==='Shipped'?'selected':'' %>>Shipped</option>
            <option <%= o.status==='Delivered'?'selected':'' %>>Delivered</option>
            <option <%= o.status==='Cancelled'?'selected':'' %>>Cancelled</option>
          </select>

          <button class="bg-blue-500 text-white px-2 py-1 ml-2 rounded">
            Update
          </button>
        </form>

      </div>

      <% }) %>

    </div>

  </div>

</div>

<!-- JS -->
<script>
function showTab(tab){
  document.querySelectorAll(".tab-content").forEach(el=>el.classList.add("hidden"));
  document.getElementById(tab).classList.remove("hidden");
}
</script>

<script>
const dropArea = document.getElementById("dropArea");
const input = document.getElementById("imageInput");
const preview = document.getElementById("previewContainer");

let filesArray = [];

dropArea.addEventListener("click", ()=> input.click());

dropArea.addEventListener("dragover", e=>{
  e.preventDefault();
  dropArea.classList.add("bg-gray-200");
});

dropArea.addEventListener("dragleave", ()=> {
  dropArea.classList.remove("bg-gray-200");
});

dropArea.addEventListener("drop", e=>{
  e.preventDefault();
  dropArea.classList.remove("bg-gray-200");
  handleFiles(Array.from(e.dataTransfer.files));
});

input.addEventListener("change", e=>{
  handleFiles(Array.from(e.target.files));
});

function handleFiles(files){
  if(filesArray.length + files.length > 5){
    alert("Max 5 images allowed!");
    return;
  }
  files.forEach(f=>filesArray.push(f));
  updatePreview();
}

function updatePreview(){
  preview.innerHTML="";
  const dt=new DataTransfer();

  filesArray.forEach((file,index)=>{
    dt.items.add(file);

    const reader=new FileReader();
    reader.onload=e=>{
      const div=document.createElement("div");
      div.className="relative";

      div.innerHTML=`
        <img src="${e.target.result}" class="w-24 h-24 object-cover rounded border">
        <button onclick="removeImage(${index})"
        class="absolute top-0 right-0 bg-red-500 text-white text-xs px-2 rounded">❌</button>
      `;

      preview.appendChild(div);
    };

    reader.readAsDataURL(file);
  });

  input.files=dt.files;
}

function removeImage(index){
  filesArray.splice(index,1);
  updatePreview();
}
</script>

</body>
</html>