<%- include("partial/nav") %>

<div class="bg-white">

  <!-- HEADER -->
  <div class="bg-gray-100 border-b">
    <div class="max-w-5xl mx-auto px-4 py-8">
      <h1 class="text-3xl md:text-4xl font-bold text-gray-800">
        Return & Refund Policy
      </h1>
      <p class="text-gray-600 mt-2 text-sm">
        Last Updated: March 2026
      </p>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="max-w-5xl mx-auto px-4 py-8 space-y-8 text-gray-700 leading-relaxed">

    <!-- INTRO -->
    <section>
      <p>
        At <strong>LioKart</strong>, we aim to deliver the best quality products. 
        However, if you receive a wrong or damaged product, we offer a return option under the conditions below.
      </p>
    </section>

    <!-- IMPORTANT RULE -->
    <section class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
      <h2 class="text-lg font-semibold mb-2 text-red-600">
        ⚠️ Important Return Condition
      </h2>
      <p>
        Customers are strictly advised to <strong>open and check the product in front of the delivery person (supplier)</strong> at the time of delivery.
      </p>
      <p class="mt-2">
        If the product is found to be wrong, damaged, or has any issue, 
        it must be <strong>returned immediately at the time of delivery</strong>.
      </p>
      <p class="mt-2 font-semibold text-red-600">
        ❌ Returns will NOT be accepted once the delivery person leaves.
      </p>
    </section>

    <!-- ELIGIBILITY -->
    <section>
      <h2 class="text-xl font-semibold mb-2">1. Return Eligibility</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li>Wrong product delivered</li>
        <li>Damaged or defective product</li>
        <li>Missing items in the package</li>
      </ul>
    </section>

    <!-- NON RETURN -->
    <section>
      <h2 class="text-xl font-semibold mb-2">2. Non-Returnable Cases</h2>
      <ul class="list-disc pl-6 space-y-1">
        <li>Product checked and accepted after delivery</li>
        <li>Used or damaged by the customer</li>
        <li>Return request made after delivery completion</li>
      </ul>
    </section>

    <!-- REFUND -->
    <section>
      <h2 class="text-xl font-semibold mb-2">3. Refund Policy</h2>
      <p>
        Once the return is accepted at the time of delivery, your refund will be processed within 5-7 working days 
        to your original payment method.
      </p>
    </section>

    <!-- CONTACT -->
    <section>
      <h2 class="text-xl font-semibold mb-2">4. Contact Us</h2>
      <p>Email: liokartshop@gmail.com</p>
      <p>Phone: +91 8578908969</p>
      <p class="mt-2">Address: Bengaluru, India</p>
    </section>

  </div>

</div>

