<!DOCTYPE html>
<html>
<head>
<title>Beauty</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto p-6">

<h1 class="text-3xl font-bold mb-6">Beauty</h1>

<div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-4 gap-6">

<% products.forEach(function(product){ %>

<div class="bg-white p-4 rounded shadow">

<img src="<%= product.images[0] %>" class="w-full h-40 object-cover">

<h2 class="text-lg font-semibold mt-3"><%= product.name.substring(0, 22) %></h2>

<p class="text-gray-600">₹ <%= product.price %></p>

<div>
    <p><span> 🚚Free Delevery </span></p>
</div>

<p class="mb-4 text-yellow-500">
⭐ Average Rating: <%= typeof avgRating !== "undefined" ? avgRating.toFixed(1) : "No rating" %>
</p>

<p class="text-gray-600">
<%= product.description.substring(0, 60) %>...
</p>

<a href="/product/<%= product._id %>" 
class="block mt-3 bg-blue-500 text-white text-center py-2 rounded">
View Details
</a>

</div>

<% }) %>

</div>

</div>

<%- include("partial/footer") %>

</body>
</html> 

