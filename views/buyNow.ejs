<!DOCTYPE html>
<html>
<head>
  <title>Buy Now</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto mt-10 grid md:grid-cols-2 gap-8 px-4">

  <!-- 🛒 LEFT: PRODUCT CARD -->
  <div class="bg-white p-6 rounded-2xl shadow-lg hover:shadow-xl transition">

    <h2 class="text-2xl font-bold mb-4 border-b pb-2">🛒 Order Summary</h2>

    <div class="overflow-hidden rounded-xl">
      <img 
src="<%= product.images && product.images.length > 0 
        ? product.images[0] 
        : (product.image ? '/uploads/' + product.image : '/default.png') %>" 
onerror="this.src='/default.png'"
class="w-full h-72 object-cover hover:scale-105 transition duration-300">
    </div>

    <h3 class="text-xl font-semibold mt-5">
      <%= product.name %>
    </h3>

    <p class="text-green-600 text-2xl font-bold mt-2">
      ₹ <%= product.price %>
    </p>

    <p class="text-gray-500 mt-3 text-sm leading-relaxed">
      <%= product.description %>
    </p>

    <div class="mt-4 text-green-600 font-semibold">
      🚚 Free Delivery | 4-5 Days
    </div>

  </div>


  <!-- 📦 RIGHT: ADDRESS FORM -->
  <div class="bg-white p-8 rounded-2xl shadow-lg">

    <!-- HEADER -->
    <h1 class="text-2xl font-bold mb-6 border-b pb-2">
      📍 Add Delivery Address
    </h1>

    <form action="/place-order" method="POST" class="space-y-5">

      <input type="hidden" name="productId" value="<%= product._id %>">

      <!-- CONTACT -->
      <div>
        <h2 class="font-semibold mb-3 text-gray-700">Contact Details</h2>

        <input type="text" name="name" placeholder="Full Name"
        class="w-full border p-3 rounded-lg mb-3 focus:ring-2 focus:ring-pink-400 outline-none" required>

        <input type="text" name="phone" placeholder="Phone Number"
        class="w-full border p-3 rounded-lg mb-3 focus:ring-2 focus:ring-pink-400 outline-none" required>

        <input type="text" name="phone2" placeholder="Alternate Number (optional)"
        class="w-full border p-3 rounded-lg focus:ring-2 focus:ring-pink-400 outline-none">

        <input type="email" name="email" placeholder="Email Address"
        class="w-full border p-3 rounded-lg mt-3 focus:ring-2 focus:ring-pink-400 outline-none" required>

      </div>
    

      <!-- ADDRESS -->
      <div>
        <h2 class="font-semibold mb-2 text-gray-700">Address</h2>

        <input type="text" name="house" placeholder="House No / Building"
        class="w-full border p-3 rounded-lg mb-3 focus:ring-2 focus:ring-pink-400 outline-none" required>

        <input type="text" name="area" placeholder="Road / Area / Colony"
        class="w-full border p-3 rounded-lg mb-3 focus:ring-2 focus:ring-pink-400 outline-none" required>

        <input type="text" name="pincode" placeholder="Pincode"
        class="w-full border p-3 rounded-lg mb-3 focus:ring-2 focus:ring-pink-400 outline-none" required>

        <div class="flex gap-2">
          <input type="text" name="city" placeholder="City"
          class="w-1/2 border p-3 rounded-lg focus:ring-2 focus:ring-pink-400 outline-none" required>

          <input type="text" name="state" placeholder="State"
          class="w-1/2 border p-3 rounded-lg focus:ring-2 focus:ring-pink-400 outline-none" required>
        </div>

        <input type="text" name="landmark" placeholder="Nearby Landmark (optional)"
        class="w-full border p-3 rounded-lg mt-3 focus:ring-2 focus:ring-pink-400 outline-none">
      </div>

   
     <!-- SIZE -->
      <%= JSON.stringify(product.sizes) %>
<% if(product.sizes && product.sizes.length > 0){ %>

<div>
  <h2 class="font-semibold mb-3 text-gray-700">Select Size</h2>

  <div class="flex gap-4 flex-wrap">

    <% product.sizes.forEach(item => { %>

      <label class="cursor-pointer">
        <input type="radio" name="size" value="<%= item.size %>" class="hidden peer" required>

        <div class="w-20 h-20 flex flex-col items-center justify-center 
        border-2 border-gray-400 rounded-full 
        peer-checked:border-black peer-checked:bg-gray-200 
        hover:bg-gray-100 transition">

          <p class="text-lg font-bold"><%= item.size %></p>
         

        </div>
      </label>

    <% }) %>

  </div>
</div>

<% } %>

      <!-- BUTTON -->
      <button class="w-full bg-gradient-to-r from-pink-500 to-purple-600 
      text-white py-3 rounded-xl text-lg font-semibold 
      hover:scale-105 transition transform shadow-md">
        🚀 Save Address & Place Order
      </button>

    </form>

  </div>

</div>

<%- include("partial/footer") %>

</body>
</html>