<!DOCTYPE html>
<html>
<head>
<title>Buy Now</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-6xl mx-auto mt-10 grid md:grid-cols-2 gap-6">

<!-- LEFT: PRODUCT -->
<div class="bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Order Summary</h2>

<img src="<%= product.image %>" class="w-full h-100 object-cover">

<h3 class="text-lg font-semibold mt-4"><%= product.name %></h3>

<p class="text-green-600 text-xl mt-2">₹ <%= product.price %></p>

<p class="text-gray-600 mt-2"><%= product.description %></p>

</div>

<!-- RIGHT: ADDRESS + PAYMENT -->
<div class="bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Delivery Details</h2>

<form action="/place-order" method="POST">

<input type="hidden" name="productId" value="<%= product._id %>">

<!-- Name -->
<input type="text" name="name" placeholder="Full Name"
class="w-full border p-2 rounded mb-3" required>

<!-- Phone -->
<input type="text" name="phone" placeholder="Mobile Number"
class="w-full border p-2 rounded mb-3" required>

<!-- Phone2 -->
<input type="text" name="phone2" placeholder="Alternate Mobile Number"
class="w-full border p-2 rounded mb-3" required>

<!-- Email -->
<input type="email" name="email" placeholder="Email Address"
class="w-full border p-2 rounded mb-3" required>

<!-- Address -->
<textarea name="address" placeholder="Full Address"
class="w-full border p-2 rounded mb-3" required></textarea>

<!-- Payment -->
<select name="payment" class="w-full border p-2 rounded mb-4">
<option value="cod">Cash on Delivery</option>
<option value="online">Online Payment</option>
</select>

<button type="submit"
class="w-full bg-green-600 text-white py-3 rounded hover:bg-green-700">

Place Order

</button>

</form>

</div>

</div>

<%- include("partial/footer") %>

</body>
</html>