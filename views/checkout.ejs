<!DOCTYPE html>
<html>
<head>
<title>Checkout</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto p-6 grid md:grid-cols-2 gap-10 mt-10">

<!-- LEFT: ADDRESS FORM -->
<div class="bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Shipping Details</h2>

<form action="/checkout" method="POST">

<input type="text" name="name" placeholder="Full Name"
class="w-full border p-2 mb-3 rounded" required>

<input type="email" name="email" placeholder="Email"
class="w-full border p-2 mb-3 rounded" required>

<input type="text" name="phone" placeholder="Phone Number"
class="w-full border p-2 mb-3 rounded" required>

<input type="text" name="phone2" placeholder="Alternate Phone Number"
class="w-full border p-2 mb-3 rounded" required>

<textarea name="address" placeholder="Full Address"
class="w-full border p-2 mb-3 rounded" required></textarea>

<button class="w-full bg-green-600 text-white py-2 rounded">
Place Order
</button>


</form>

</div>

<!-- RIGHT: ORDER SUMMARY -->
<div class="bg-white p-6 rounded shadow">

<h2 class="text-xl font-bold mb-4">Order Summary</h2>

<% if(cart.length > 0){ %>

  <% cart.forEach(item => { %>

    <div class="flex items-center gap-4 mb-4 border-b pb-3">

      <img src="/uploads/<%= item.image %>" 
      class="w-16 h-16 object-cover rounded">

      <div class="flex-1">
        <h3 class="font-semibold"><%= item.name %></h3>
        <p>Qty: <%= item.qty %></p>
      </div>

      <p class="font-bold text-green-600">
        ₹ <%= item.price * item.qty %>
      </p>

    </div>

  <% }) %>

  <div class="mt-4 border-t pt-4">

    <h3 class="text-lg font-bold">
      Total: ₹ <%= total %>
    </h3>

  </div>

<% } else { %>

<p>Your cart is empty</p>

<% } %>

</div>

</div>

<%- include("partial/footer") %>


</body>
</html>