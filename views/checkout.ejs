<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto mt-6 px-4">

<!-- 🔥 STEP HEADER -->
<div class="flex items-center gap-4 mb-6 text-sm font-semibold">

  <div class="flex items-center gap-2 bg-blue-500 text-white px-4 py-2 rounded">
    ✔ Login
  </div>

  <div class="flex items-center gap-2 bg-blue-500 text-white px-4 py-2 rounded">
    ✔ Address
  </div>

  <div class="flex items-center gap-2 bg-gray-300 px-4 py-2 rounded">
    3 Payment
  </div>

</div>

<div class="grid lg:grid-cols-3 gap-6">

<!-- LEFT SIDE -->
<div class="lg:col-span-2 space-y-5">

  <!-- 📍 ADDRESS -->
  <div class="bg-white p-6 rounded-xl shadow">

    <h2 class="font-semibold mb-4 text-lg border-b pb-2">
      📍 Delivery Address
    </h2>

    <form id="checkoutForm" action="/checkout" method="POST" class="space-y-4">

      <div class="grid md:grid-cols-2 gap-3">
        <input name="name" placeholder="Full Name" required class="border p-3 rounded-lg">
        <input name="phone" placeholder="Phone" required class="border p-3 rounded-lg">
      </div>

      <input name="email" placeholder="Email" required class="border p-3 rounded-lg w-full">

      <input name="house" placeholder="House / Building" required class="border p-3 rounded-lg w-full">
      <input name="area" placeholder="Area / Street" required class="border p-3 rounded-lg w-full">

      <div class="grid md:grid-cols-3 gap-3">
        <input name="city" placeholder="City" required class="border p-3 rounded-lg">
        <input name="state" placeholder="State" required class="border p-3 rounded-lg">
        <input name="pincode" placeholder="Pincode" required class="border p-3 rounded-lg">
      </div>

      <input name="landmark" placeholder="Landmark" class="border p-3 rounded-lg w-full">

  </div>

  <!-- 🛒 ITEMS -->
  <div class="bg-white p-6 rounded-xl shadow">

    <h2 class="font-semibold mb-4 text-lg border-b pb-2">
      🛒 Order Items
    </h2>

    <% cart.forEach(item => { %>

    <div class="flex gap-4 border-b py-4">

      <img src="<%= item.image || '/default.png' %>"
        class="w-20 h-20 object-cover rounded border">

      <div class="flex-1">

        <h3 class="font-medium text-gray-800">
          <%= item.name %>
        </h3>

        <p class="text-sm text-gray-500 mt-1">
          Qty: <%= item.qty %>
        </p>

        <p class="text-sm text-gray-500">
          ₹ <%= item.price %>
        </p>

      </div>

      <p class="font-semibold text-gray-800">
        ₹ <%= item.price * item.qty %>
      </p>

    </div>

    <% }) %>

  </div>

</div>

<!-- RIGHT SIDE -->
<div class="space-y-5">

  <!-- 💰 PRICE -->
  <div class="bg-white p-6 rounded-xl shadow sticky top-20">

    <h2 class="font-semibold mb-4 text-lg border-b pb-2">
      PRICE DETAILS
    </h2>

    <div class="space-y-3 text-sm">

      <div class="flex justify-between">
        <span>Price</span>
        <span>₹ <%= total %></span>
      </div>

      <div class="flex justify-between">
        <span>Delivery Charges</span>
        <span class="text-green-600">FREE</span>
      </div>

      <div class="flex justify-between">
        <span>GST (10%)</span>
        <span>₹ <%= Math.round(total * 0.10) %></span>
      </div>

      <hr>

      <div class="flex justify-between font-bold text-lg">
        <span>Total</span>
        <span>
          ₹ <%= total + Math.round(total * 0.10) %>
        </span>
      </div>

    </div>

    <!-- 💳 BUTTONS -->
    <div class="mt-6 space-y-3">

      <button type="submit"
        class="w-full bg-blue-500 hover:bg-blue-600 text-white py-3 rounded-lg font-semibold">
        Cash on Delivery
      </button>

      <button type="button" onclick="payNow()"
        class="w-full bg-yellow-400 hover:bg-yellow-500 py-3 rounded-lg font-semibold">
        Pay with Razorpay
      </button>

    </div>

  </div>

</div>

</div>

</form>

</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>

<script>
async function payNow() {

  const form = document.getElementById("checkoutForm");
  const formData = new FormData(form);
  const data = Object.fromEntries(formData.entries());

  if (!data.name || !data.phone || !data.house) {
    alert("Please fill all required fields");
    return;
  }

  try {

    // ✅ CREATE ORDER
    const res = await fetch("/create-order", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        amount: <%= total + Math.round(total * 0.18) %>
      })
    });

    const order = await res.json();

    const options = {
      key: "<%= razorpayKey %>",
      amount: order.amount,
      currency: "INR",
      order_id: order.id,
      name: "LioKart",
      description: "Secure Payment",

      handler: async function (response) {

        const verify = await fetch("/verify-payment", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            ...response,
            address: data
          })
        });

        const result = await verify.json();

        if (result.success) {

          const input = document.createElement("input");
          input.type = "hidden";
          input.name = "paymentMethod";
          input.value = "ONLINE";

          form.appendChild(input);
          form.submit();

        } else {
          alert("Payment Failed ❌");
        }
      },

      prefill: {
        name: data.name,
        email: data.email,
        contact: data.phone
      },

      theme: {
        color: "#2874F0"
      }
    };

    new Razorpay(options).open();

  } catch (err) {
    console.log(err);
    alert("Something went wrong ❌");
  }
}
</script>

</body>
</html>