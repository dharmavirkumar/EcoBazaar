<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<div class="max-w-7xl mx-auto mt-10 grid md:grid-cols-2 gap-8 px-4">

  <!-- 🛒 LEFT: CART SUMMARY -->
  <div class="bg-white p-6 rounded-2xl shadow-lg">

    <h2 class="text-2xl font-bold mb-4 border-b pb-2">🛒 Order Summary</h2>

    <% if(cart.length > 0){ %>

      <% cart.forEach(item => { %>

        <div class="flex items-center gap-4 mb-4 border-b pb-3">

          <!-- IMAGE -->
          <img src="<%= item.image %>" 
          class="w-20 h-20 object-cover rounded">

          <!-- DETAILS -->
          <div class="flex-1">
            <h3 class="font-semibold"><%= item.name %></h3>
            <p class="text-gray-500 text-sm">Qty: <%= item.qty %></p>
          </div>

          <!-- PRICE -->
          <p class="text-green-600 font-bold">
            ₹ <%= item.price * item.qty %>
          </p>

        </div>

      <% }) %>

      <!-- TOTAL -->
      <div class="mt-4 border-t pt-4">
        <h3 class="text-xl font-bold">
          Total: ₹ <%= total %>
        </h3>
      </div>

    <% } else { %>

      <p class="text-gray-500">Your cart is empty 😔</p>

    <% } %>

  </div>


  <!-- 📦 RIGHT: ADDRESS FORM -->
  <div class="bg-white p-8 rounded-2xl shadow-lg">

    <h1 class="text-2xl font-bold mb-6 border-b pb-2">
      📍 Add Delivery Address
    </h1>

    <form action="/checkout" method="POST" class="space-y-5">

      <!-- CONTACT -->
      <div>
        <h2 class="font-semibold mb-3 text-gray-700">Contact Details</h2>

        <input type="text" name="name" placeholder="Full Name"
        class="w-full border p-3 rounded-lg mb-3" required>

        <input type="text" name="phone" placeholder="Phone Number"
        class="w-full border p-3 rounded-lg mb-3" required>

        <input type="text" name="phone2" placeholder="Alternate Number"
        class="w-full border p-3 rounded-lg">

        <input type="email" name="email" placeholder="Email Address"
        class="w-full border p-3 rounded-lg mt-3" required>
      </div>

      <!-- ADDRESS -->
      <div>
        <h2 class="font-semibold mb-2 text-gray-700">Address</h2>

        <input type="text" name="house" placeholder="House No / Building"
        class="w-full border p-3 rounded-lg mb-3" required>

        <input type="text" name="area" placeholder="Road / Area / Colony"
        class="w-full border p-3 rounded-lg mb-3" required>

        <input type="text" name="pincode" placeholder="Pincode"
        class="w-full border p-3 rounded-lg mb-3" required>

        <div class="flex gap-2">
          <input type="text" name="city" placeholder="City"
          class="w-1/2 border p-3 rounded-lg" required>

          <input type="text" name="state" placeholder="State"
          class="w-1/2 border p-3 rounded-lg" required>
        </div>

        <input type="text" name="landmark" placeholder="Nearby Landmark"
        class="w-full border p-3 rounded-lg mt-3">
      </div>

      <!-- OPTIONAL SIZE -->
      <div>
        <h2 class="font-semibold mb-3 text-gray-700">Select Size (Optional)</h2>

        <select name="size" class="w-full border p-3 rounded">
          <option value="">Select Size</option>
          <option>S</option>
          <option>M</option>
          <option>L</option>
          <option>XL</option>
        </select>
      </div>

      <!-- BUTTON -->
      <button class="w-full bg-gradient-to-r from-pink-500 to-purple-600 
      text-white py-3 rounded-xl text-lg font-semibold 
      hover:scale-105 transition shadow-md">
        🚀 Place Order
      </button>

    </form>

  </div>

</div>

<%- include("partial/footer") %>

</body>
</html>