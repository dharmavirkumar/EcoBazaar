<body class="bg-gray-100 text-gray-900">

<%- include("partial/nav") %>

<!-- ================= HELPERS ================= -->
<%
function getFinalPrice(p){
  if(p.discountType === "percentage"){
    return Math.round(p.price - (p.price * p.discountValue / 100));
  } else if(p.discountType === "fixed"){
    return p.price - p.discountValue;
  }
  return p.price;
}
%>

<!-- ================= HERO SLIDER ================= -->
<div class="max-w-7xl mx-auto px-2 mt-3">
  <div class="overflow-hidden rounded-lg">
    <div id="slider" class="flex transition-transform duration-700">

      <% ["banner1.png","companytr.png","banner1.png"].forEach(img => { %>
        <div class="min-w-full">
          <img 
            src="/uploads/<%= img %>" 
            class="w-full h-40 sm:h-64 object-cover"
            loading="lazy"
          >
        </div>
      <% }) %>

    </div>
  </div>
</div>

<!-- ================= CATEGORY ================= -->
<div class="bg-white mt-3 shadow-sm">
  <div class="max-w-7xl mx-auto flex gap-6 overflow-x-auto px-3 py-3 text-xs sm:text-sm">

    <% const categories = [
      {name:"Men",icon:"👕",link:"/category/fashion/All"},
      {name:"Women",icon:"👗",link:"/category/women/All"},
      {name:"Beauty",icon:"💄",link:"/category/beauty/All"},
      {name:"Electronics",icon:"📱",link:"/category/electronics/All"},
      {name:"More",icon:"👜",link:"/category/accessories/All"}
    ]; %>

    <% categories.forEach(c => { %>
      <a href="<%= c.link %>" class="flex flex-col items-center min-w-[70px] active:scale-95 transition">
        <div class="text-xl"><%= c.icon %></div>
        <span class="mt-1"><%= c.name %></span>
      </a>
    <% }) %>

  </div>
</div>

<!-- ================= PRODUCT CARD ================= -->
<%
function productCard(p){ %>

<div class="bg-white rounded-md overflow-hidden shadow-sm hover:shadow-md transition">

  <a href="/product/<%= p._id %>">
    <img 
      src="<%= p.images?.[0] %>" 
      loading="lazy"
      class="w-full h-36 object-contain bg-white"
    >
  </a>

  <div class="p-2">

    <p class="text-xs sm:text-sm line-clamp-2 h-10">
      <%= p.name %>
    </p>

    <div class="mt-1 flex flex-wrap items-center gap-1">

      <span class="font-bold text-sm">
        ₹<%= getFinalPrice(p) %>
      </span>

      <% if(p.discountType && p.discountType !== "none"){ %>
        <span class="line-through text-gray-400 text-xs">
          ₹<%= p.price %>
        </span>

        <span class="text-green-600 text-xs font-semibold">
          <%= p.discountType === "percentage" 
              ? p.discountValue + "% OFF"
              : "₹" + p.discountValue + " OFF"
          %>
        </span>
      <% } %>

    </div>

  </div>
</div>

<% } %>

<!-- ================= TRENDING ================= -->
<div class="max-w-7xl mx-auto px-2 mt-6">

  <h2 class="text-base font-bold mb-2">🔥 Trending</h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">

    <% products.forEach(p => { %>
      <%- productCard(p) %>
    <% }) %>

  </div>
</div>

<!-- ================= MEN ================= -->
<div class="max-w-7xl mx-auto px-2 mt-8">

  <div class="flex justify-between mb-2">
    <h2 class="font-bold">👕 Men's Wear</h2>
    <a href="/category/fashion/All" class="text-blue-600 text-xs">View All</a>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">

    <% menProducts.forEach(p => { %>
      <%- productCard(p) %>
    <% }) %>

  </div>
</div>

<!-- ================= WOMEN ================= -->
<div class="max-w-7xl mx-auto px-2 mt-8">

  <div class="flex justify-between mb-2">
    <h2 class="font-bold">👗 Women's Wear</h2>
    <a href="/category/women/All" class="text-blue-600 text-xs">View All</a>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-2">

    <% womenProducts.forEach(p => { %>
      <%- productCard(p) %>
    <% }) %>

  </div>
</div>

<!-- ================= TRUST ================= -->
<div class="bg-white mt-8 py-5">
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 text-center text-xs gap-3">

    <div>🚚 Free Delivery</div>
    <div>💰 COD Available</div>
    <div>🔄 Easy Returns</div>
    <div>🔒 Secure Payments</div>

  </div>
</div>

<%- include("partial/footer") %>

<!-- ================= SLIDER SCRIPT ================= -->
<script>
const slider = document.getElementById("slider");
let index = 0;

setInterval(() => {
  index = (index + 1) % 3;
  slider.style.transform = `translateX(-${index * 100}%)`;
}, 3000);
</script>

</body>