<!DOCTYPE html>
<html>
<head>
  <title>Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔥 HERO -->
<div class="bg-gradient-to-r from-blue-500 to-purple-600 text-white py-12">
  <div class="max-w-7xl mx-auto px-4 flex flex-col md:flex-row items-center justify-between gap-10">

    <div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4">
        Shop Smart, Live Better 🛒
      </h1>
      <p class="mb-6">Best deals on electronics, fashion & more</p>

      <a href="/electronics"
        class="bg-white text-blue-600 px-6 py-2 rounded-lg font-semibold hover:bg-gray-200">
        Shop Now
      </a>
    </div>

    <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png"
      class="w-56 md:w-72">
  </div>
</div>

<!-- 🔥 PRODUCTS -->
<div class="max-w-7xl mx-auto px-4 mt-12">

<h2 class="text-2xl font-bold mb-6">🔥 Trending Products</h2>

<div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

<% products.forEach(product => { %>

<div class="bg-white rounded-xl shadow hover:shadow-xl transition overflow-hidden group relative">

<!-- ❤️ WISHLIST -->
<button class="absolute top-2 right-2 bg-white p-2 rounded-full shadow hover:bg-red-100">
  ❤️
</button>

<!-- 🏷 SALE BADGE -->
<% if(product.discountType && product.discountType !== "none"){ %>
<span class="absolute top-2 left-2 bg-red-500 text-white text-xs px-2 py-1 rounded">
  SALE
</span>
<% } %>

<!-- IMAGE -->
<div class="relative overflow-hidden">

<img 
src="<%= product.images && product.images.length > 0 
        ? product.images[0] 
        : '/uploads/' + product.image %>" 
class="w-full h-48 object-cover transition duration-500 group-hover:opacity-0">

<% if(product.images && product.images.length > 1){ %>
<img 
src="<%= product.images[1] %>" 
class="w-full h-48 object-cover absolute top-0 left-0 opacity-0 group-hover:opacity-100 transition duration-500">
<% } %>

</div>

<!-- CONTENT -->
<div class="p-4">

<h3 class="font-semibold truncate"><%= product.name %></h3>

<p class="font-bold mt-2">

<% if(product.discountType && product.discountType !== "none"){ %>

<span class="line-through text-gray-400">
₹ <%= product.price %>
</span>

<span class="text-green-600 ml-2">
₹ <%= product.finalPrice %>
</span>

<% } else { %>

₹ <%= product.price %>

<% } %>

</p>

<p class="text-gray-500 text-sm mt-2">
<%= product.description 
? product.description.substring(0, 50) 
: "No description" %>...
</p>

<!-- BUTTONS -->
<div class="flex gap-2 mt-4">

<a href="/product/<%= product._id %>"
class="flex-1 text-center bg-blue-500 text-white py-2 rounded hover:bg-blue-600">
View
</a>

<button onclick="addToCart('<%= product._id %>')"
class="flex-1 bg-pink-500 text-white py-2 rounded hover:bg-pink-600">
Cart
</button>

</div>

</div>

</div>

<% }) %>

</div>
</div>

<!-- ✅ POPUP -->
<div id="popup" class="fixed bottom-5 right-5 bg-green-500 text-white px-4 py-2 rounded shadow hidden">
  ✅ Added to cart
</div>

<%- include("partial/footer") %>

<!-- JS -->
<script>
async function addToCart(id){
  await fetch('/add-to-cart/' + id);

  const popup = document.getElementById("popup");
  popup.classList.remove("hidden");

  setTimeout(()=>{
    popup.classList.add("hidden");
  },2000);
}
</script>

</body>
</html>