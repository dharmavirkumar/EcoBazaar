<!DOCTYPE html>
<html>
<head>
  <title>Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔥 HERO SECTION -->
<div class="bg-gradient-to-r from-blue-500 to-purple-600 text-white py-16">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between">

    <div>
      <h1 class="text-4xl font-bold mb-4">Shop Smart, Live Better 🛒</h1>
      <p class="text-lg mb-6">Best deals on electronics, fashion & more</p>

      <a href="/electronics"
        class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-200">
        Shop Now
      </a>
    </div>

    <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png"
         class="w-72 mt-8 md:mt-0">
  </div>
</div>


<!-- 🧩 CATEGORIES -->
<div class="max-w-7xl mx-auto px-6 mt-10">

  <h2 class="text-2xl font-bold mb-6">Shop by Category</h2>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-6">

    <a href="/electronics" class="bg-white p-6 rounded-xl shadow hover:shadow-lg text-center">
      📱 <p class="mt-2 font-semibold">Electronics</p>
    </a>

    <a href="/men" class="bg-white p-6 rounded-xl shadow hover:shadow-lg text-center">
      👕 <p class="mt-2 font-semibold">Fashion</p>
    </a>

    <a href="/beauty" class="bg-white p-6 rounded-xl shadow hover:shadow-lg text-center">
      💄 <p class="mt-2 font-semibold">Beauty</p>
    </a>

    <a href="/jewellery" class="bg-white p-6 rounded-xl shadow hover:shadow-lg text-center">
      💍 <p class="mt-2 font-semibold">Jewellery</p>
    </a>

  </div>

</div>


<!-- 🔥 TRENDING PRODUCTS -->
<div class="max-w-7xl mx-auto px-6 mt-12">

  <h2 class="text-2xl font-bold mb-6">🔥 Trending Products</h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">

  <% products.forEach(product => { %>

    <div class="bg-white rounded-xl shadow hover:shadow-xl transition overflow-hidden group">

      <!-- IMAGE -->
      <div class="overflow-hidden">
        <img src="<%= product.image %>" 
             class="w-full h-48 object-cover group-hover:scale-110 transition duration-300">
      </div>

      <!-- CONTENT -->
      <div class="p-4">

        <h3 class="font-semibold text-lg truncate">
          <%= product.name %>
        </h3>

        <p class="text-green-600 font-bold text-xl mt-1">
          ₹ <%= product.price %>
        </p>

        <p class="text-gray-500 text-sm mt-2">
          <%= product.description.substring(0, 50) %>...
        </p>

        <!-- BUTTONS -->
        <div class="flex gap-3 mt-4">

          <a href="/product/<%= product._id %>"
            class="flex-1 text-center bg-blue-500 text-white py-2 rounded-lg hover:bg-blue-600">
            View
          </a>

          <a href="/add-to-cart/<%= product._id %>"
            class="flex-1 text-center bg-pink-500 text-white py-2 rounded-lg hover:bg-pink-600">
            Cart
          </a>

        </div>

      </div>

    </div>

  <% }) %>

  </div>

</div>


<!-- 💎 OFFER BANNER -->
<div class="max-w-7xl mx-auto px-6 mt-12">
  <div class="bg-yellow-400 p-6 rounded-xl text-center font-semibold text-lg">
    🎉 Big Sale! Get up to 50% OFF on selected items
  </div>
</div>


<!-- FOOTER -->
<%- include("partial/footer") %>

</body>
</html>