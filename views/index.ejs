<!DOCTYPE html>
<html>
<head>
  <title>Home</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>
<div class="relative overflow-hidden rounded-xl">

  <!-- SLIDER -->
  <div id="heroSlider" class="flex transition-transform duration-700 ease-in-out">

    <!-- SLIDE 1 -->
    <div class="min-w-full h-56 md:h-80">
      <img src="/uploads/companytr.png"
           class="w-full h-full object-contain bg-white">
    </div>

    <!-- SLIDE 2 -->
    <div class="min-w-full h-56 md:h-80">
      <img src="/uploads/banner1.png"
           class="w-full h-full object-cover">
    </div>

    <!-- SLIDE 3 -->
    <div class="min-w-full h-56 md:h-80">
      <img src="/images/banner3.jpg"
           class="w-full h-full object-cover">
    </div>

  </div>

  <!-- DOTS -->
  <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2">
    <span class="dot w-2 h-2 bg-white/80 rounded-full"></span>
    <span class="dot w-2 h-2 bg-white/40 rounded-full"></span>
    <span class="dot w-2 h-2 bg-white/40 rounded-full"></span>
  </div>

</div>

<!-- 🔥 CATEGORY BAR -->
<div class="bg-white sticky top-16 z-40 shadow-sm">

  <div id="catBar"
       class="flex gap-8 overflow-x-auto py-3 px-4 scroll-smooth">

    <% const categories = [
      {name: "Men Wear", main: "fashion", icon: "👕"},
      {name: "Women Wear", main: "women", icon: "👚"},
      {name: "Accessories", main: "accessories", icon: "👜"},
      {name: "Beauty", main: "beauty", icon: "💄"},
      {name: "Electronics", main: "electronics", icon: "📱"}
    ]; %>

    <% categories.forEach(cat => { %>

      <a href="/category/<%= cat.main %>/All"
         class="cat-item flex flex-col items-center min-w-[80px] text-sm text-gray-600 hover:text-blue-600">

        <div class="text-2xl"><%= cat.icon %></div>
        <span><%= cat.name %></span>

        <span class="underline-bar h-[2px] w-0 bg-blue-600 mt-1 transition-all"></span>
      </a>

    <% }) %>

  </div>

</div>

<!-- 🔥 PRODUCTS -->
<div class="max-w-7xl mx-auto px-4 mt-6">

<h2 class="text-xl font-bold mb-5">🔥 Trending Products</h2>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">

<% products.forEach(product => { %>

<div class="bg-white rounded-xl overflow-hidden group hover:shadow-2xl transition">

  <!-- IMAGE -->
  <div class="bg-gray-50 p-3 relative">

    <% if(product.discountType && product.discountType !== "none"){ %>
      <span class="absolute top-2 left-2 bg-pink-500 text-white text-xs px-2 py-1 rounded">
        SALE
      </span>
    <% } %>

    <a href="/product/<%= product._id %>">
      <img 
        src="<%= product.images?.[0] || '/default.png' %>" 
        class="w-full h-40 object-contain group-hover:scale-110 transition">
    </a>

  </div>

  <!-- DETAILS -->
  <div class="p-3">

    <p class="text-xs text-gray-400 uppercase">
      <%= product.mainCategory %>
    </p>

    <h3 class="text-sm font-semibold line-clamp-2">
      <%= product.name %>
    </h3>

    <div class="flex gap-2 items-center mt-1">

      <% if(product.discountType && product.discountType !== "none"){ %>

        <span class="font-bold">₹ <%= product.finalPrice %></span>
        <span class="line-through text-gray-400 text-xs">
          ₹ <%= product.price %>
        </span>

      <% } else { %>

        <span class="font-bold">₹ <%= product.price %></span>

      <% } %>

    </div>
      
    <p class="text-xs text-green-600 mt-1">Free Delivery</p>

  </div>

  <!-- BUTTON -->
  <div class="px-3 pb-3 opacity-0 group-hover:opacity-100 transition">

    <button onclick="addToCart('<%= product._id %>')"
      class="w-full border border-gray-300 hover:bg-black hover:text-white py-2 text-xs rounded">
      ADD TO BAG
    </button>

  </div>

</div>

<% }) %>

</div>

</div>

<!-- POPUP -->
<div id="popup" class="fixed bottom-5 right-5 bg-green-500 text-white px-4 py-2 rounded hidden">
  Added to cart ✅
</div>

<%- include("partial/footer") %>

<!-- JS -->
<script>
async function addToCart(id){
  await fetch('/add-to-cart/' + id);

  const popup = document.getElementById("popup");
  popup.classList.remove("hidden");

  setTimeout(()=>{
    popup.classList.add("hidden");
  },2000);
}
</script>

<!-- CATEGORY ACTIVE -->
<script>
const path = window.location.pathname.toLowerCase();

document.querySelectorAll(".cat-item").forEach(item => {

  const href = item.getAttribute("href").toLowerCase();

  if (path.includes(href.split("/")[2])) {
    item.classList.add("text-blue-600");

    const bar = item.querySelector(".underline-bar");
    bar.style.width = "100%";
  }

  item.addEventListener("mouseenter", () => {
    item.querySelector(".underline-bar").style.width = "100%";
  });

  item.addEventListener("mouseleave", () => {
    if (!item.classList.contains("text-blue-600")) {
      item.querySelector(".underline-bar").style.width = "0";
    }
  });

});
</script>

<script>
const slider = document.getElementById("heroSlider");
const dots = document.querySelectorAll(".dot");

let index = 0;

function updateSlider() {
  slider.style.transform = `translateX(-${index * 100}%)`;

  dots.forEach((d, i) => {
    d.classList.toggle("bg-white/80", i === index);
    d.classList.toggle("bg-white/40", i !== index);
  });
}

setInterval(() => {
  index = (index + 1) % 3;
  updateSlider();
}, 3000);
</script>
</body>
</html>