<!DOCTYPE html>
<html>
<head>
  <title>Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔥 HERO BANNER -->
<div class="bg-white shadow mt-2">
  <div class="max-w-7xl mx-auto p-4">

    <div class="grid md:grid-cols-3 gap-4">

      <div class="md:col-span-2 bg-gradient-to-r from-blue-500 to-indigo-600 text-white p-6 rounded-xl flex items-center justify-between">
        <div>
          <h1 class="text-3xl font-bold">Big Billion Sale Comming Soon 🎉</h1>
          <p class="mt-2">Up to 70% OFF</p>
        </div>
        <img src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png" class="w-32">
      </div>

      <div class="bg-gradient-to-r from-pink-500 to-red-500 text-white p-6 rounded-xl">
        <h2 class="text-xl font-bold">Fashion Deals 👕</h2>
        <p>Min 50% OFF</p>
      </div>

    </div>

  </div>
</div>

<!-- 🔥 CATEGORY BAR -->
<div class="bg-white shadow-sm border-b sticky top-16 z-40">

  <div class="max-w-7xl mx-auto px-4">

    <div id="catBar"
         class="flex gap-10 overflow-x-auto scrollbar-hide py-3 relative">

      <% const categories = [
        {name: "Fashion", main: "fashion"},
        {name: "Accessories", main: "accessories"},
        {name: "Beauty", main: "beauty"},
        {name: "Electronics", main: "electronics"}
        
      ]; %>

      <% categories.forEach(cat => { %>

        <a href="/category/<%= cat.main %>/All"
           class="cat-item relative whitespace-nowrap text-sm font-medium text-gray-600 hover:text-blue-600 transition">

          <span class="cat-text"><%= cat.name %></span>

          <!-- UNDERLINE -->
          <span class="underline-bar absolute left-0 -bottom-1 h-[2px] w-0 bg-blue-600 transition-all duration-300"></span>

        </a>

      <% }) %>

    </div>

  </div>

</div>
<!-- 🔥 PRODUCTS SECTION -->
<div class="max-w-7xl mx-auto px-4 mt-6">

<h2 class="text-xl font-semibold mb-4">Trending Products</h2>

<div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">

<% products.forEach(product => { %>

<div class="bg-white border hover:shadow-lg transition rounded-lg p-3 relative">

<!-- SALE TAG -->
<% if(product.discountType && product.discountType !== "none"){ %>
<span class="absolute top-2 left-2 bg-green-500 text-white text-xs px-2 py-1 rounded">
  Sale
</span>
<% } %>

<!-- IMAGE -->
<a href="/product/<%= product._id %>">
  <img 
  src="<%= product.images?.[0] || '/default.png' %>" 
  class="w-full h-36 object-contain">
</a>

<!-- NAME -->
<h3 class="text-sm mt-2 font-medium truncate">
  <%= product.name %>
</h3>

<!-- PRICE -->
<p class="mt-1 text-sm">

<% if(product.discountType && product.discountType !== "none"){ %>

<span class="line-through text-gray-400">
₹ <%= product.price %>
</span>

<span class="text-green-600 font-bold ml-2">
₹ <%= product.finalPrice %>
</span>

<% } else { %>

<span class="font-bold">₹ <%= product.price %></span>

<% } %>

</p>

<!-- DELIVERY -->
<p class="text-xs text-green-600 mt-1">Free Delivery</p>

<!-- BUTTON -->
<button onclick="addToCart('<%= product._id %>')"
class="w-full mt-3 bg-yellow-400 hover:bg-yellow-500 text-black py-1 rounded text-sm">
Add to Cart
</button>

</div>

<% }) %>

</div>

</div>

<!-- POPUP -->
<div id="popup" class="fixed bottom-5 right-5 bg-green-500 text-white px-4 py-2 rounded shadow hidden">
  Added to cart ✅
</div>

<%- include("partial/footer") %>

<!-- JS -->
<script>
async function addToCart(id){
  await fetch('/add-to-cart/' + id);

  const popup = document.getElementById("popup");
  popup.classList.remove("hidden");

  setTimeout(()=>{
    popup.classList.add("hidden");
  },2000);
}
</script>
<script>
const path = window.location.pathname.toLowerCase();

document.querySelectorAll(".cat-item").forEach(item => {

  const href = item.getAttribute("href").toLowerCase();

  if (path.includes(href.split("/")[2])) {

    // active text
    item.classList.add("text-blue-600", "font-semibold");

    // underline full
    const bar = item.querySelector(".underline-bar");
    bar.style.width = "100%";
  }

  // hover animation
  item.addEventListener("mouseenter", () => {
    item.querySelector(".underline-bar").style.width = "100%";
  });

  item.addEventListener("mouseleave", () => {
    if (!item.classList.contains("text-blue-600")) {
      item.querySelector(".underline-bar").style.width = "0";
    }
  });

});
</script>
<script>
const catBar = document.getElementById("catBar");

let isDown = false;
let startX;
let scrollLeft;

catBar.addEventListener("mousedown", (e) => {
  isDown = true;
  startX = e.pageX - catBar.offsetLeft;
  scrollLeft = catBar.scrollLeft;
});

catBar.addEventListener("mouseleave", () => {
  isDown = false;
});

catBar.addEventListener("mouseup", () => {
  isDown = false;
});

catBar.addEventListener("mousemove", (e) => {
  if (!isDown) return;
  e.preventDefault();
  const x = e.pageX - catBar.offsetLeft;
  const walk = (x - startX) * 2;
  catBar.scrollLeft = scrollLeft - walk;
});
</script>

</body>
</html>