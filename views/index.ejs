<!DOCTYPE html>
<html>
<head>
  <title>Home</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100">

<%- include("partial/nav") %>

<!-- 🔥 HERO SECTION -->
<div class="bg-gradient-to-r from-blue-500 to-purple-600 text-white py-12 sm:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 flex flex-col-reverse md:flex-row items-center justify-between gap-10">

    <!-- TEXT -->
    <div class="text-center md:text-left">
      <h1 class="text-2xl sm:text-3xl md:text-4xl font-bold mb-4 leading-tight">
        Shop Smart, Live Better 🛒
      </h1>

      <p class="text-sm sm:text-base md:text-lg mb-6">
        Best deals on electronics, fashion & more
      </p>

      <a href="/electronics"
        class="inline-block bg-white text-blue-600 px-6 py-2 sm:py-3 rounded-lg font-semibold hover:bg-gray-200 transition">
        Shop Now
      </a>
    </div>

    <!-- IMAGE -->
    <img 
      src="https://cdn-icons-png.flaticon.com/512/3144/3144456.png"
      class="w-40 sm:w-56 md:w-72"
    >
  </div>
</div>


<!-- 🧩 CATEGORIES -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 mt-8 sm:mt-10">

  <h2 class="text-xl sm:text-2xl font-bold mb-6 text-center md:text-left">
    Shop by Category
  </h2>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-4 sm:gap-6">

    <a href="/electronics" class="bg-white p-4 sm:p-6 rounded-xl shadow hover:shadow-lg text-center transition">
      <div class="text-2xl sm:text-3xl">📱</div>
      <p class="mt-2 font-semibold text-sm sm:text-base">Electronics</p>
    </a>

    <a href="/men" class="bg-white p-4 sm:p-6 rounded-xl shadow hover:shadow-lg text-center transition">
      <div class="text-2xl sm:text-3xl">👕</div>
      <p class="mt-2 font-semibold text-sm sm:text-base">Fashion</p>
    </a>

    <a href="/beauty" class="bg-white p-4 sm:p-6 rounded-xl shadow hover:shadow-lg text-center transition">
      <div class="text-2xl sm:text-3xl">💄</div>
      <p class="mt-2 font-semibold text-sm sm:text-base">Beauty</p>
    </a>

    <a href="/jewellery" class="bg-white p-4 sm:p-6 rounded-xl shadow hover:shadow-lg text-center transition">
      <div class="text-2xl sm:text-3xl">💍</div>
      <p class="mt-2 font-semibold text-sm sm:text-base">Jewellery</p>
    </a>

  </div>

</div>


<!-- 🔥 TRENDING PRODUCTS -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 mt-10 sm:mt-12">

  <h2 class="text-xl sm:text-2xl font-bold mb-6 text-center md:text-left">
    🔥 Trending Products
  </h2>

  <div class="grid grid-cols-1 xs:grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 sm:gap-6">

  <% products.forEach(product => { %>

    <div class="bg-white rounded-xl shadow hover:shadow-xl transition overflow-hidden group flex flex-col">

      <!-- IMAGE -->
      <div class="overflow-hidden">
        <img 
          src="<%= product.image %>" 
          onerror="this.src='https://via.placeholder.com/300'"
          class="w-full h-44 sm:h-48 object-cover group-hover:scale-110 transition duration-300"
        >
      </div>

      <!-- CONTENT -->
      <div class="p-4 flex flex-col flex-grow">

        <h3 class="font-semibold text-sm sm:text-base truncate">
          <%= product.name %>
        </h3>

        <p class="text-green-600 font-bold text-lg sm:text-xl mt-1">
          ₹ <%= product.price %>
        </p>

        <p class="text-gray-500 text-xs sm:text-sm mt-2 line-clamp-2">
          <%= product.description ? product.description.substring(0, 60) : "" %>...
        </p>

        <!-- BUTTONS -->
        <div class="flex gap-2 sm:gap-3 mt-4 mt-auto">

          <a href="/product/<%= product._id %>"
            class="flex-1 text-center bg-blue-500 text-white py-2 text-sm rounded-lg hover:bg-blue-600 transition">
            View
          </a>

          <a href="/add-to-cart/<%= product._id %>"
            class="flex-1 text-center bg-pink-500 text-white py-2 text-sm rounded-lg hover:bg-pink-600 transition">
            Cart
          </a>

        </div>

      </div>

    </div>

  <% }) %>

  </div>

</div>


<!-- 💎 OFFER BANNER -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 mt-10 sm:mt-12">
  <div class="bg-yellow-400 p-4 sm:p-6 rounded-xl text-center font-semibold text-sm sm:text-lg">
    🎉 Big Sale! Get up to 50% OFF on selected items
  </div>
</div>


<!-- FOOTER -->
<%- include("partial/footer") %>

</body>
</html>